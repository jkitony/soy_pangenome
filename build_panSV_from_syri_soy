#!/bin/bash
set -euo pipefail

############################################
# User settings
############################################
REF_FASTA="Gmax_MU-Wm82-a5ref_PI518671_hardmasked.fasta"
SYRI_ROOT="syri_soy_genomes_syri_out"
MINLEN=50
MERGE_DIST=1000
OUTDIR="panSV_build"
PYTHON_SCRIPT="syri_out_to_vcf.py"
SV_TYPES="INS,DEL,INV,DUP"

############################################
# Checks
############################################
command -v python >/dev/null 2>&1 || { echo "[ERROR] python not found"; exit 1; }
command -v samtools >/dev/null 2>&1 || { echo "[ERROR] samtools not found"; exit 1; }
command -v bcftools >/dev/null 2>&1 || { echo "[ERROR] bcftools not found"; exit 1; }
command -v tabix >/dev/null 2>&1 || { echo "[ERROR] tabix not found"; exit 1; }
command -v SURVIVOR >/dev/null 2>&1 || { echo "[ERROR] SURVIVOR not found in PATH"; exit 1; }

[[ -f "${REF_FASTA}" ]] || { echo "[ERROR] Missing reference FASTA: ${REF_FASTA}"; exit 1; }
[[ -d "${SYRI_ROOT}" ]] || { echo "[ERROR] Missing SyRI root directory: ${SYRI_ROOT}"; exit 1; }
[[ -f "${PYTHON_SCRIPT}" ]] || { echo "[ERROR] Missing Python converter: ${PYTHON_SCRIPT}"; exit 1; }

if [[ ! -f "${REF_FASTA}.fai" ]]; then
    echo "[INFO] Indexing reference FASTA..."
    samtools faidx "${REF_FASTA}"
fi

############################################
# Output folders
############################################
RAW_VCF_DIR="${OUTDIR}/01_raw_vcf"
PLAIN_VCF_DIR="${OUTDIR}/02_plain_sorted_vcf"
GZ_VCF_DIR="${OUTDIR}/03_sorted_vcfgz"
MERGE_DIR="${OUTDIR}/04_merged"

mkdir -p "${RAW_VCF_DIR}" "${PLAIN_VCF_DIR}" "${GZ_VCF_DIR}" "${MERGE_DIR}"

############################################
# Step 1. Find syri.out files
############################################
echo "[INFO] Searching for SyRI output files under: ${SYRI_ROOT}"

mapfile -t SYRI_FILES < <(find "${SYRI_ROOT}" -type f -name "*syrisyri.out" | sort)

if [[ ${#SYRI_FILES[@]} -eq 0 ]]; then
    echo "[ERROR] No files matching *syrisyri.out found under ${SYRI_ROOT}"
    exit 1
fi

echo "[INFO] Found ${#SYRI_FILES[@]} SyRI output files."

############################################
# Step 2. Convert each syri.out to VCF
############################################
count=0

for syri_file in "${SYRI_FILES[@]}"; do
    dir=$(dirname "${syri_file}")
    base_dir=$(basename "${dir}")

    # Example: Gcan_PI583945.a01_syri -> Gcan_PI583945.a01
    sample="${base_dir%_syri}"

    raw_vcf="${RAW_VCF_DIR}/${sample}.sv.ge${MINLEN}.vcf"
    plain_sorted_vcf="${PLAIN_VCF_DIR}/${sample}.sv.ge${MINLEN}.sorted.vcf"
    gz_sorted_vcf="${GZ_VCF_DIR}/${sample}.sv.ge${MINLEN}.sorted.vcf.gz"

    echo "[INFO] Processing ${sample}"

    python "${PYTHON_SCRIPT}" \
        --syri "${syri_file}" \
        --fai "${REF_FASTA}.fai" \
        --sample "${sample}" \
        --out "${raw_vcf}" \
        --minlen "${MINLEN}" \
        --types "${SV_TYPES}"

    bcftools sort -Ov -o "${plain_sorted_vcf}" "${raw_vcf}"
    bcftools sort -Oz -o "${gz_sorted_vcf}" "${raw_vcf}"
    tabix -f -p vcf "${gz_sorted_vcf}"

    rm -f "${raw_vcf}"

    n=$(bcftools view -H "${gz_sorted_vcf}" | wc -l)
    echo "[OK] ${sample} -> ${n} SVs"

    count=$((count+1))
done

echo "[INFO] Finished ${count} samples."

############################################
# Step 3. Build SURVIVOR input list
############################################
ls "${PLAIN_VCF_DIR}"/*.sorted.vcf > "${MERGE_DIR}/panSV_vcf_list.txt"
nfiles=$(wc -l < "${MERGE_DIR}/panSV_vcf_list.txt")
echo "[INFO] SURVIVOR will merge ${nfiles} VCF files."

############################################
# Step 4. Merge with SURVIVOR
############################################
echo "[INFO] Running SURVIVOR merge..."
SURVIVOR merge \
    "${MERGE_DIR}/panSV_vcf_list.txt" \
    "${MERGE_DIST}" \
    1 \
    1 \
    0 \
    0 \
    "${MINLEN}" \
    "${MERGE_DIR}/panSV_merged.unsorted.vcf"

############################################
# Step 5. Sort merged VCF and index
############################################
echo "[INFO] Sorting merged VCF..."
bcftools sort \
    -Ov \
    -o "${MERGE_DIR}/panSV_merged.sorted.vcf" \
    "${MERGE_DIR}/panSV_merged.unsorted.vcf"

bcftools sort \
    -Oz \
    -o "${MERGE_DIR}/panSV_merged.sorted.vcf.gz" \
    "${MERGE_DIR}/panSV_merged.unsorted.vcf"

tabix -f -p vcf "${MERGE_DIR}/panSV_merged.sorted.vcf.gz"

############################################
# Step 6. Quick summaries
############################################
echo "[INFO] Final merged VCF:"
echo "  ${MERGE_DIR}/panSV_merged.sorted.vcf.gz"

echo "[INFO] Total merged SVs:"
bcftools view -H "${MERGE_DIR}/panSV_merged.sorted.vcf.gz" | wc -l

echo "[INFO] SV type counts:"
bcftools query -f '%INFO/SVTYPE\n' "${MERGE_DIR}/panSV_merged.sorted.vcf.gz" | sort | uniq -c

echo "[INFO] Support distribution:"
bcftools query -f '%INFO/SUPP\n' "${MERGE_DIR}/panSV_merged.sorted.vcf.gz" | sort -n | uniq -c | head -20

echo "[DONE]"
