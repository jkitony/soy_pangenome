#Fig.X (a)
#!/usr/bin/env python3

import json
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.patheffects as pe
import numpy as np
from matplotlib.patches import Patch
from matplotlib.lines import Line2D

# =========================================================
# FILES
# =========================================================
meta_file = "Meta.csv"
geojson_file = "world.geojson.json"
out_csv = "Meta_with_plot_coordinates_ecotype.csv"
out_png = "soybean_ecotype_map_4x2in.png"
out_pdf = "soybean_ecotype_map_4x2in.pdf"

# =========================================================
# USER SETTINGS
# =========================================================
ECOTYPE_COL = "Ecotype"

MAP_EXTENT = [-180, 180, -90, 90]
FIG_WIDTH = 4
FIG_HEIGHT = 2
PNG_DPI = 600

SAMPLED_COUNTRY_FILL = "#cfe8f3"
UNSAMPLED_COUNTRY_FILL = "#e0e0e0"
COUNTRY_EDGE = "white"

ECOTYPE_COLORS = {
    "Cultivar": "#f28e2b",
    "Landrace": "#4e79a7",
    "Wild_type": "#2ca25f",
    "Breeder_line": "#8e63ce",
}

ECOTYPE_OFFSETS = {
    "Cultivar": -1.0,
    "Landrace": -0.35,
    "Wild_type": 0.35,
    "Breeder_line": 1.0,
}

POINT_ALPHA = 0.95
USE_LOG_SIZE = True
SIZE_SCALE = 12
LINEAR_SIZE_SCALE = 5
MIN_SIZE = 9

LABEL_MIN_COUNT = 10
LABEL_SIZE = 4.6
TITLE_SIZE = 7
LEGEND_SIZE = 4.7

# =========================================================
# READ METADATA SAFELY
# =========================================================
try:
    df = pd.read_csv(meta_file, encoding="utf-8")
except UnicodeDecodeError:
    df = pd.read_csv(meta_file, encoding="latin1", low_memory=False)

df.columns = df.columns.str.strip()

if "Origin country" in df.columns and "Country" not in df.columns:
    df = df.rename(columns={"Origin country": "Country"})

if "Country" not in df.columns:
    raise ValueError("Column 'Country' not found in Meta.csv")

if "Location" not in df.columns:
    df["Location"] = pd.NA

if ECOTYPE_COL not in df.columns:
    raise ValueError(f"Column '{ECOTYPE_COL}' not found in Meta.csv")

# =========================================================
# CLEAN TEXT
# =========================================================
for col in ["Country", "Location", ECOTYPE_COL]:
    df[col] = df[col].astype(str).str.strip()

missing_vals = {"NA", "N/A", "Unknown", "unknown", "", "nan", "None", "<NA>"}
df["Country"] = df["Country"].apply(lambda x: pd.NA if x in missing_vals else x)
df["Location"] = df["Location"].apply(lambda x: pd.NA if x in missing_vals else x)
df[ECOTYPE_COL] = df[ECOTYPE_COL].apply(lambda x: pd.NA if x in missing_vals else x)

df = df.dropna(subset=["Country", ECOTYPE_COL]).copy()

# =========================================================
# STANDARDIZE ECOTYPE LABELS
# =========================================================
ecotype_fix = {
    "cultivar": "Cultivar",
    "landrace": "Landrace",
    "wild type": "Wild_type",
    "wild_type": "Wild_type",
    "Wild type": "Wild_type",
    "wild": "Wild_type",
    "breeder line": "Breeder_line",
    "breeder_line": "Breeder_line",
    "Breeder line": "Breeder_line",
}
df[ECOTYPE_COL] = df[ECOTYPE_COL].replace(ecotype_fix)

df = df[df[ECOTYPE_COL].isin(ECOTYPE_COLORS.keys())].copy()

# =========================================================
# COUNTRY NAME NORMALIZATION
# =========================================================
country_fix = {
    "USA": "United States of America",
    "U.S.A.": "United States of America",
    "United States": "United States of America",
    "Korea": "South Korea",
}
df["Country"] = df["Country"].replace(country_fix)

# =========================================================
# OPTIONAL EXACT LOCATION COORDINATES
# =========================================================
location_coords = {
    ("United States of America", "Illinois"): ("Illinois, USA", 40.6331, -89.3985),
    ("South Korea", "Seoul"): ("Seoul, South Korea", 37.5665, 126.9780),
    ("China", "Sichuan"): ("Sichuan, China", 30.6517, 104.0759),
    ("China", "sichuan"): ("Sichuan, China", 30.6517, 104.0759),
    ("Japan", "Kyushu"): ("Kyushu, Japan", 33.0000, 130.5000),
    ("Japan", "Tokyo"): ("Tokyo, Japan", 35.6762, 139.6503),
    ("Tanzania", "Dodoma"): ("Dodoma, Tanzania", -6.1630, 35.7516),
}

# =========================================================
# LOAD GEOJSON
# =========================================================
with open(geojson_file, "r", encoding="utf-8") as f:
    geo = json.load(f)

def get_feature_name(feature):
    props = feature.get("properties", {})
    for key in ["name", "ADMIN", "admin", "NAME", "country", "COUNTRY"]:
        if key in props and props[key]:
            return str(props[key]).strip()
    return None

# =========================================================
# BUILD COUNTRY CENTROIDS
# =========================================================
country_centroids = {}

for feature in geo["features"]:
    name = get_feature_name(feature)
    if not name:
        continue

    geom = feature.get("geometry")
    if geom is None:
        continue

    coords_list = []

    if geom["type"] == "Polygon":
        for ring in geom["coordinates"]:
            coords_list.extend(ring)

    elif geom["type"] == "MultiPolygon":
        for poly in geom["coordinates"]:
            for ring in poly:
                coords_list.extend(ring)

    if coords_list:
        xs, ys = zip(*coords_list)
        country_centroids[name] = (sum(ys) / len(ys), sum(xs) / len(xs))

geojson_name_fix = {
    "United States of America": "United States of America",
    "South Korea": "South Korea",
    "North Korea": "North Korea",
    "Russia": "Russia",
    "Vietnam": "Vietnam",
    "Taiwan": "Taiwan",
    "Serbia": "Republic of Serbia",
    "Tanzania": "United Republic of Tanzania",
}

# =========================================================
# ASSIGN COORDINATES
# =========================================================
def assign_coords(row):
    country = row["Country"]
    location = row["Location"]

    if pd.notna(location):
        key = (country, location)
        if key in location_coords:
            place, lat, lon = location_coords[key]
            return pd.Series([place, lat, lon, "reported_location"])

    geo_country = geojson_name_fix.get(country, country)
    if geo_country in country_centroids:
        lat, lon = country_centroids[geo_country]
        return pd.Series([geo_country, lat, lon, "centroid"])

    return pd.Series([pd.NA, pd.NA, pd.NA, "unmapped"])

df[["Plot_place", "Latitude", "Longitude", "Coord_source"]] = df.apply(assign_coords, axis=1)
df_mapped = df.dropna(subset=["Latitude", "Longitude"]).copy()
df_mapped.to_csv(out_csv, index=False)

# =========================================================
# AGGREGATE BY LOCATION + ECOTYPE
# =========================================================
agg = (
    df_mapped
    .groupby(
        ["Plot_place", "Latitude", "Longitude", "Coord_source", ECOTYPE_COL],
        dropna=False
    )
    .size()
    .reset_index(name="Count")
)

if USE_LOG_SIZE:
    agg["Size"] = np.log1p(agg["Count"]) * SIZE_SCALE + MIN_SIZE
else:
    agg["Size"] = agg["Count"] * LINEAR_SIZE_SCALE + MIN_SIZE

agg["Plot_lon"] = agg["Longitude"] + agg[ECOTYPE_COL].map(ECOTYPE_OFFSETS).fillna(0)

sampled_countries = set(
    geojson_name_fix.get(c, c)
    for c in df_mapped["Country"].dropna().unique()
)

# =========================================================
# PLOT
# =========================================================
fig, ax = plt.subplots(figsize=(FIG_WIDTH, FIG_HEIGHT))

for feature in geo["features"]:
    geom = feature.get("geometry")
    if geom is None:
        continue

    name = get_feature_name(feature)
    facecolor = SAMPLED_COUNTRY_FILL if name in sampled_countries else UNSAMPLED_COUNTRY_FILL

    if geom["type"] == "Polygon":
        for ring in geom["coordinates"]:
            xs, ys = zip(*ring)
            ax.fill(xs, ys, facecolor=facecolor, edgecolor=COUNTRY_EDGE, linewidth=0.25, zorder=1)

    elif geom["type"] == "MultiPolygon":
        for poly in geom["coordinates"]:
            for ring in poly:
                xs, ys = zip(*ring)
                ax.fill(xs, ys, facecolor=facecolor, edgecolor=COUNTRY_EDGE, linewidth=0.25, zorder=1)

for eco_class in ["Cultivar", "Landrace", "Wild_type", "Breeder_line"]:
    sub = agg[agg[ECOTYPE_COL] == eco_class]
    if len(sub) == 0:
        continue

    ax.scatter(
        sub["Plot_lon"],
        sub["Latitude"],
        s=sub["Size"],
        c=ECOTYPE_COLORS[eco_class],
        alpha=POINT_ALPHA,
        edgecolors="black",
        linewidths=0.3,
        zorder=3,
        label=eco_class
    )

for _, row in agg.iterrows():
    if row["Count"] >= LABEL_MIN_COUNT:
        txt = ax.text(
            row["Plot_lon"],
            row["Latitude"],
            str(row["Count"]),
            fontsize=LABEL_SIZE,
            ha="center",
            va="center",
            color="white",
            weight="bold",
            zorder=4
        )
        txt.set_path_effects([pe.withStroke(linewidth=1.0, foreground="black")])

country_legend = [
    Patch(facecolor=SAMPLED_COUNTRY_FILL, edgecolor=COUNTRY_EDGE, label="Sampled"),
    Patch(facecolor=UNSAMPLED_COUNTRY_FILL, edgecolor=COUNTRY_EDGE, label="Unsampled"),
]

dot_legend = [
    Line2D([0], [0], marker="o", color="w", label="Cultivar",
           markerfacecolor=ECOTYPE_COLORS["Cultivar"], markeredgecolor="black", markersize=4.8),
    Line2D([0], [0], marker="o", color="w", label="Landrace",
           markerfacecolor=ECOTYPE_COLORS["Landrace"], markeredgecolor="black", markersize=4.8),
    Line2D([0], [0], marker="o", color="w", label="Wild_type",
           markerfacecolor=ECOTYPE_COLORS["Wild_type"], markeredgecolor="black", markersize=4.8),
    Line2D([0], [0], marker="o", color="w", label="Breeder_line",
           markerfacecolor=ECOTYPE_COLORS["Breeder_line"], markeredgecolor="black", markersize=4.8),
]

legend1 = ax.legend(
    handles=country_legend,
    loc="lower left",
    bbox_to_anchor=(0.02, 0.42),
    fontsize=LEGEND_SIZE,
    frameon=False,
    handlelength=0.9,
    handletextpad=0.3,
    labelspacing=0.25,
    borderpad=0.2
)
ax.add_artist(legend1)

ax.legend(
    handles=dot_legend,
    loc="lower left",
    bbox_to_anchor=(0.02, 0.13),
    fontsize=LEGEND_SIZE,
    frameon=False,
    handlelength=0.9,
    handletextpad=0.3,
    labelspacing=0.25,
    borderpad=0.2
)

ax.set_xlim(MAP_EXTENT[0], MAP_EXTENT[1])
ax.set_ylim(MAP_EXTENT[2], MAP_EXTENT[3])
ax.set_aspect("auto")
ax.set_xticks([])
ax.set_yticks([])

for spine in ax.spines.values():
    spine.set_visible(False)

ax.set_title("Soybean accessions", fontsize=TITLE_SIZE, pad=2)

fig.subplots_adjust(left=0.01, right=0.995, top=0.92, bottom=0.03)

plt.savefig(out_png, dpi=PNG_DPI, bbox_inches="tight", pad_inches=0.01)
plt.savefig(out_pdf, bbox_inches="tight", pad_inches=0.01)
plt.show()

unmapped = df[df["Coord_source"] == "unmapped"].copy()
print(f"Saved coordinate table: {out_csv}")
print(f"Saved PNG: {out_png}")
print(f"Saved PDF: {out_pdf}")
print(f"Mapped samples: {len(df_mapped)}")
print(f"Unique plotted location-class combinations: {len(agg)}")
if len(unmapped) > 0:
    print("\nUnmapped country names:")
    print(unmapped["Country"].value_counts())
