#!/usr/bin/env python3

import pandas as pd
import re

phenofile = "Phenotypes.csv"
metafile = "Meta_FINAL.csv"

# -----------------------------
# Read CSVs with flexible encoding
# -----------------------------
def read_any_csv(fname):
    for enc in ["utf-8", "utf-8-sig", "cp1252", "latin1"]:
        try:
            print(f"Reading {fname} with encoding: {enc}")
            return pd.read_csv(fname, encoding=enc)
        except UnicodeDecodeError:
            continue
    raise ValueError(f"Could not read {fname}")

pheno = read_any_csv(phenofile)
meta = read_any_csv(metafile)

# -----------------------------
# Clean PI names for matching
# -----------------------------
def clean_pi(x):
    if pd.isna(x):
        return ""

    x = str(x).strip()

    # Convert underscores to spaces first
    x = x.replace("__", " ")
    x = x.replace("_", " ")

    # Remove extra spaces
    x = re.sub(r"\s+", " ", x)

    # PI 548406 -> PI548406
    x = re.sub(r"\bPI\s+", "PI", x)

    # PI 549023 B -> PI549023B
    x = re.sub(r"(PI\d+)\s+([A-Za-z])$", r"\1\2", x)

    # PI 548402 -2 -> PI548402-2
    x = re.sub(r"\s*-\s*", "-", x)

    # Remove remaining spaces only for PI-style accessions
    if x.startswith("PI"):
        x = x.replace(" ", "")

    return x

pheno["PI_clean"] = pheno["PI"].apply(clean_pi)
meta["PI_clean"] = meta["PI"].apply(clean_pi)

# -----------------------------
# Merge phenotype and metadata
# -----------------------------
meta_keep = [
    "Sample",
    "PI",
    "PI_clean",
    "Species",
    "Germplasm_type",
    "Country",
    "Location",
    "Maturity_group"
]

merged = pheno.merge(
    meta[meta_keep],
    on="PI_clean",
    how="left",
    suffixes=("_pheno", "_meta")
)

# -----------------------------
# Save all merged rows
# -----------------------------
merged.to_csv("Phenotypes_with_Maturity_group.csv", index=False)

# -----------------------------
# Save unmatched rows
# -----------------------------
unmatched = merged[merged["Maturity_group"].isna()].copy()

unmatched.to_csv(
    "Phenotypes_not_found_in_Meta_FINAL.csv",
    index=False
)

# -----------------------------
# Save matched rows only
# -----------------------------
matched = merged[merged["Maturity_group"].notna()].copy()

matched.to_csv(
    "Phenotypes_with_Maturity_group_matched.csv",
    index=False
)

# -----------------------------
# Save matched rows with known MG only
# -----------------------------
matched_known = matched[matched["Maturity_group"] != "Unknown"].copy()

matched_known.to_csv(
    "Phenotypes_with_Maturity_group_matched_knownMG.csv",
    index=False
)

# -----------------------------
# Save clean plotting-ready file
# -----------------------------
clean_cols = [
    "PI_pheno",
    "PI_clean",
    "Origin",
    "Flowering_Date",
    "Height",
    "Maturity_Date",
    "Sample",
    "Species",
    "Germplasm_type",
    "Country",
    "Location",
    "Maturity_group"
]

# Keep only columns that exist
clean_cols = [c for c in clean_cols if c in matched_known.columns]

clean = matched_known[clean_cols].copy()

clean.to_csv(
    "Phenotypes_MG_clean.csv",
    index=False
)

# -----------------------------
# Save unmatched PI summary
# -----------------------------
unmatched_cols = [
    "PI_pheno",
    "PI_clean",
    "Origin",
    "Flowering_Date",
    "Height",
    "Maturity_Date"
]

unmatched_cols = [c for c in unmatched_cols if c in unmatched.columns]

unmatched_summary = unmatched[unmatched_cols].drop_duplicates()

unmatched_summary.to_csv(
    "Unmatched_PI_summary_for_manual_cleaning.csv",
    index=False
)

# -----------------------------
# Print summary
# -----------------------------
print("\nMerge summary")
print("-------------")
print("Total phenotype rows:", len(pheno))
print("Matched rows:", len(matched))
print("Matched rows with known MG:", len(matched_known))
print("Unmatched rows:", len(unmatched))

print("\nFiles written:")
print("1. Phenotypes_with_Maturity_group.csv")
print("2. Phenotypes_with_Maturity_group_matched.csv")
print("3. Phenotypes_with_Maturity_group_matched_knownMG.csv")
print("4. Phenotypes_MG_clean.csv")
print("5. Phenotypes_not_found_in_Meta_FINAL.csv")
print("6. Unmatched_PI_summary_for_manual_cleaning.csv")

print("\nUnmatched PI values:")
print(unmatched_summary.head(50))

