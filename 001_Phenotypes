        alternative="two-sided"
    )

    sig = significance_label(pval)

    fig, ax = plt.subplots(figsize=(1.2, 1.2))

    # Individual points first, behind boxes
    np.random.seed(42)

    for i, vals in enumerate([north_vals, south_vals], start=1):
        x = np.random.normal(
            loc=i,
            scale=0.035,
            size=len(vals)
        )

        ax.scatter(
            x,
            vals,
            s=1.8,
            color="black",
            alpha=0.22,
            linewidth=0,
            zorder=1
        )

    # Boxplot on top of points
    bp = ax.boxplot(
        [north_vals, south_vals],
        patch_artist=True,
        widths=0.55,
        showfliers=False,
        zorder=2
    )

    bp["boxes"][0].set_facecolor("green")
    bp["boxes"][1].set_facecolor("orange")

    for box in bp["boxes"]:
        box.set_alpha(0.75)
        box.set_linewidth(0.7)
        box.set_zorder(2)

    for median in bp["medians"]:
        median.set_color("black")
        median.set_linewidth(0.8)
        median.set_zorder(3)

    for whisker in bp["whiskers"]:
        whisker.set_linewidth(0.7)
        whisker.set_zorder(2)

    for cap in bp["caps"]:
        cap.set_linewidth(0.7)
        cap.set_zorder(2)

    ymax = max(north_vals.max(), south_vals.max())
    ymin = min(north_vals.min(), south_vals.min())
    yrange = ymax - ymin

    if yrange == 0:
        yrange = 1

    bar_y = ymax + 0.06 * yrange
    bar_h = 0.03 * yrange

    ax.plot(
        [1, 1, 2, 2],
        [bar_y, bar_y + bar_h, bar_y + bar_h, bar_y],
        lw=0.7,
        color="black"
    )

    ax.text(
        1.5,
        bar_y + bar_h,
        sig,
        ha="center",
        va="bottom",
        fontsize=7,
        fontweight="bold"
