#!/usr/bin/env python3

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import mannwhitneyu

# -----------------------------
# Input
# -----------------------------
infile = "Phenotypes_MG_clean.csv"
df = pd.read_csv(infile)

# -----------------------------
# Clean semicolon-separated trait values
# -----------------------------
def clean_trait(x):
    if pd.isna(x):
        return np.nan

    x = str(x).strip()

    vals = []
    for v in x.split(";"):
        v = v.strip()

        if v in ["", "0", "NA", "NaN", "nan", "None"]:
            continue

        try:
            vals.append(float(v))
        except ValueError:
            continue

    if len(vals) == 0:
        return np.nan

    return np.mean(vals)

traits = ["Flowering_Date", "Height", "Maturity_Date"]

for trait in traits:
    df[trait] = df[trait].apply(clean_trait)

# -----------------------------
# Define two extreme adaptation groups
# -----------------------------
north_early = ["MG_000", "MG_00", "MG_0", "MG_I", "MG_II"]
south_late = ["MG_V", "MG_VI", "MG_VII", "MG_VIII", "MG_IX"]

def assign_adaptation_group(mg):
    if mg in north_early:
        return "North_Early"
    elif mg in south_late:
        return "South_Late"
    else:
        return np.nan

df["Adaptation_group"] = df["Maturity_group"].apply(assign_adaptation_group)

# Keep only North_Early and South_Late
df = df.dropna(subset=["Adaptation_group"]).copy()

# Save cleaned data used for plotting
df.to_csv("Phenotypes_MG_clean_NorthEarly_SouthLate_for_boxplots.csv", index=False)

# -----------------------------
# Significance label
# -----------------------------
def significance_label(p):
    if pd.isna(p):
        return "n/a"
    elif p < 0.001:
        return "***"
    elif p < 0.01:
        return "**"
    elif p < 0.05:
        return "*"
    else:
        return "ns"

# -----------------------------
# Boxplot function
# -----------------------------
def plot_trait_boxplot(data, trait, ylabel=None, outprefix=None):
    plot_df = data.dropna(subset=[trait, "Adaptation_group"]).copy()

    order = ["North_Early", "South_Late"]
    colors = ["green", "orange"]

    north_vals = plot_df.loc[
        plot_df["Adaptation_group"] == "North_Early", trait
    ].dropna()

    south_vals = plot_df.loc[
        plot_df["Adaptation_group"] == "South_Late", trait
    ].dropna()

    if len(north_vals) < 2 or len(south_vals) < 2:
        pval = np.nan
        sig = "n/a"
    else:
        stat, pval = mannwhitneyu(
            north_vals,
            south_vals,
            alternative="two-sided"
        )
        sig = significance_label(pval)

    fig, ax = plt.subplots(figsize=(4.2, 4.8))

    box_data = [north_vals, south_vals]

    bp = ax.boxplot(
        box_data,
        tick_labels=order,
        patch_artist=True,
        widths=0.55,
        showfliers=False
    )

    for patch, color in zip(bp["boxes"], colors):
        patch.set_facecolor(color)
        patch.set_alpha(0.75)

    for median in bp["medians"]:
        median.set_color("black")
        median.set_linewidth(1.5)

    # Add jittered points
    np.random.seed(42)
    for i, vals in enumerate(box_data, start=1):
        x = np.random.normal(i, 0.04, size=len(vals))
        ax.scatter(
            x,
            vals,
            color="black",
            alpha=0.55,
            s=18,
            zorder=3
        )

    # Significance bar
    ymax = plot_df[trait].max()
    ymin = plot_df[trait].min()
    yrange = ymax - ymin

    if yrange == 0:
        yrange = ymax * 0.1 if ymax != 0 else 1

    bar_y = ymax + 0.08 * yrange
    text_y = ymax + 0.12 * yrange

    ax.plot(
        [1, 1, 2, 2],
        [bar_y, bar_y + 0.03 * yrange, bar_y + 0.03 * yrange, bar_y],
        color="black",
        linewidth=1
    )

    ax.text(
        1.5,
        text_y,
        sig,
        ha="center",
        va="bottom",
        fontsize=13,
        fontweight="bold"
    )

    if ylabel is None:
        ylabel = trait.replace("_", " ")

    ax.set_ylabel(ylabel, fontsize=12)
    ax.set_xlabel("")
    ax.set_title(f"{ylabel} by soybean adaptation group", fontsize=12)

    ax.set_xticklabels(
        ["North Early\nMG_000–MG_II", "South Late\nMG_V–MG_IX"],
        fontsize=10
    )

    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    ax.text(
        0.5,
        -0.22,
        f"North n={len(north_vals)}; South n={len(south_vals)}",
        transform=ax.transAxes,
        ha="center",
        fontsize=9
    )

    ax.text(
        0.5,
        -0.28,
        f"Mann–Whitney U p={pval:.3g}" if not np.isnan(pval) else "p=n/a",
        transform=ax.transAxes,
        ha="center",
        fontsize=9
    )

    plt.tight_layout()

    if outprefix is None:
        outprefix = trait

    png_file = f"{outprefix}_NorthEarly_vs_SouthLate_boxplot.png"
    pdf_file = f"{outprefix}_NorthEarly_vs_SouthLate_boxplot.pdf"

    plt.savefig(png_file, dpi=300, bbox_inches="tight")
    plt.savefig(pdf_file, bbox_inches="tight")
    plt.close()

    # Print summary statistics
    print("\n" + "=" * 70)
    print(f"{trait}")
    print("=" * 70)

    print(f"Saved PNG: {png_file}")
    print(f"Saved PDF: {pdf_file}")

    print(f"\nNorth_Early n={len(north_vals)}")
    print(north_vals.describe())

    print(f"\nSouth_Late n={len(south_vals)}")
    print(south_vals.describe())

    print(f"\nMann–Whitney U p-value = {pval}")
    print(f"Significance = {sig}")

    return {
        "Trait": trait,
        "North_n": len(north_vals),
        "South_n": len(south_vals),
        "North_mean": north_vals.mean(),
        "South_mean": south_vals.mean(),
        "North_median": north_vals.median(),
        "South_median": south_vals.median(),
        "North_sd": north_vals.std(),
        "South_sd": south_vals.std(),
        "p_value": pval,
        "significance": sig
    }

# -----------------------------
# Make plots and collect stats
# -----------------------------
results = []

results.append(
    plot_trait_boxplot(
        df,
        "Flowering_Date",
        ylabel="Flowering date",
        outprefix="Flowering_Date"
    )
)

results.append(
    plot_trait_boxplot(
        df,
        "Height",
        ylabel="Plant height",
        outprefix="Height"
    )
)

results.append(
    plot_trait_boxplot(
        df,
        "Maturity_Date",
        ylabel="Maturity date",
        outprefix="Maturity_Date"
    )
)

# -----------------------------
# Save summary statistics table
# -----------------------------
summary = pd.DataFrame(results)

summary.to_csv(
    "NorthEarly_vs_SouthLate_trait_statistics.csv",
    index=False
)

print("\n" + "=" * 70)
print("Summary table")
print("=" * 70)
print(summary)

print("\nSaved summary statistics:")
print("NorthEarly_vs_SouthLate_trait_statistics.csv")

print("\nSaved cleaned plotting data:")
print("Phenotypes_MG_clean_NorthEarly_SouthLate_for_boxplots.csv")

# ============================================================
# Additional small publication-quality plots
# Keeps the larger slide figures unchanged
# Includes individual points behind boxplots
# ============================================================

