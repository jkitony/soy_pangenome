    ax.spines["bottom"].set_linewidth(0.6)

    ax.set_ylim(ymin - 0.04 * yrange, ymax + 0.18 * yrange)

    plt.tight_layout(pad=0.15)

    png_file = f"{outprefix}_small_publication.png"
    pdf_file = f"{outprefix}_small_publication.pdf"

    plt.savefig(
        png_file,
        dpi=600,
        bbox_inches="tight",
        transparent=True
    )

    plt.savefig(
        pdf_file,
        bbox_inches="tight",
        transparent=True
    )

    plt.close()

    print(f"Saved: {png_file}")
    print(f"Saved: {pdf_file}")
    print(f"{trait}: North n={len(north_vals)}, South n={len(south_vals)}, p={pval:.3e}, sig={sig}")


# Generate only small publication panels for Fig. 8f,g
plot_small_publication_boxplot(
