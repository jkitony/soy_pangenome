############
# one-time channel setup
conda config --add channels bioconda
conda config --add channels conda-forge
conda config --set channel_priority strict

# create a new env
mamba create -n pancg_env python=3.10 tree wget pip -y
mamba activate pancg_env

# install main conda packages
mamba install -c conda-forge tree -y
mamba install -c bioconda -c conda-forge orthofinder -y
pip install jcvi
mamba install -c bioconda -c conda-forge phast -y
mamba install -c bioconda -c conda-forge diamond blast -y
####

# install panCG
pip install panCG

# quick checks
panCG -h
orthofinder -h
diamond --version
blastp -version
phyloFit --help
tree --version
