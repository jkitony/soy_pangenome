#!/usr/bin/env python3

import pandas as pd
import matplotlib.pyplot as plt

# ============================================================
# Inputs
# ============================================================

fst_file = "NorthEarly_vs_SouthLate_100kb_meanFST.bed"
candidate_file = "maturity_genes_one_per_chr.bed"

out_png = "AllChr_maturity_candidate_FST_panel_labelHighOnly.png"
out_pdf = "AllChr_maturity_candidate_FST_panel_labelHighOnly.pdf"

genome_mean_fst = 0.036055

# ============================================================
# Read FST windows
# ============================================================

fst = pd.read_csv(
    fst_file,
    sep=r"\s+",
    header=None,
    names=["chr", "start", "end", "fst"]
)

fst["fst"] = pd.to_numeric(fst["fst"], errors="coerce")
fst = fst.dropna(subset=["fst"]).copy()

fst["start"] = fst["start"].astype(int)
fst["end"] = fst["end"].astype(int)
fst["mid_mb"] = (fst["start"] + fst["end"]) / 2 / 1e6

# Label only high-FST candidates
label_threshold = fst["fst"].quantile(0.95)

print("Genome mean FST:", genome_mean_fst)
print("Top 5% FST threshold:", label_threshold)

# ============================================================
# Read candidate genes
# BED: chr start end gene
# ============================================================

genes = pd.read_csv(
    candidate_file,
    sep="\t",
    header=None,
    names=["chr", "start", "end", "gene"]
)

genes["start"] = genes["start"].astype(int)
genes["end"] = genes["end"].astype(int)
genes["mid_mb"] = (genes["start"] + genes["end"]) / 2 / 1e6

# ============================================================
# Chromosome order
# ============================================================

available = fst["chr"].unique().tolist()

if "Chr01" in available:
    chrom_order = [f"Chr{i:02d}" for i in range(1, 21)]
else:
    chrom_order = [f"Chr{i}" for i in range(1, 21)]

# ============================================================
# Plot
# ============================================================

fig, axes = plt.subplots(
    5,
    4,
    figsize=(11, 9),
    sharey=True
)

axes = axes.flatten()

global_ymax = fst["fst"].max()
ylim_top = global_ymax * 1.45

label_summary = []

for ax, chrom in zip(axes, chrom_order):

    sub = fst[fst["chr"] == chrom].copy()
    gsub = genes[genes["chr"] == chrom].copy()

    if len(sub) == 0:
        ax.axis("off")
        continue

    ax.plot(
        sub["mid_mb"],
        sub["fst"],
        color="black",
        linewidth=0.6,
        zorder=1
    )

    ax.scatter(
        sub["mid_mb"],
        sub["fst"],
        color="black",
        s=3,
        alpha=0.8,
        linewidth=0,
        zorder=2
    )

    ax.axhline(
        genome_mean_fst,
        color="gray",
        linestyle="--",
        linewidth=0.5,
        zorder=0
    )

    gsub = gsub.sort_values("mid_mb").reset_index(drop=True)

    for _, g in gsub.iterrows():

        start_mb = g["start"] / 1e6
        end_mb = g["end"] / 1e6
        mid_mb = g["mid_mb"]
        name = g["gene"]

        # Always draw candidate region
        ax.axvspan(
            start_mb,
            end_mb,
            color="red",
            alpha=0.16,
            zorder=0
        )

        # FST windows overlapping gene body
        local = sub[
            (sub["end"] >= g["start"]) &
            (sub["start"] <= g["end"])
        ]

        if len(local) == 0:
            continue

        local_max_fst = local["fst"].max()

        # Only label high-FST candidates
        if local_max_fst < label_threshold:
            continue

        y_label = global_ymax * 1.12

        ax.annotate(
            name,
            xy=(mid_mb, local_max_fst),
            xytext=(mid_mb, y_label),
            fontsize=5,
            rotation=90,
            ha="center",
            va="bottom",
            arrowprops=dict(
                arrowstyle="-",
                color="red",
                lw=0.35,
                shrinkA=0,
                shrinkB=0
            )
        )

        label_summary.append({
            "chr": chrom,
            "gene": name,
            "start": g["start"],
            "end": g["end"],
            "local_max_fst": local_max_fst
        })

    ax.set_title(chrom, fontsize=8)
    ax.set_ylim(0, ylim_top)

    ax.tick_params(
        axis="both",
        labelsize=6,
        length=2,
        width=0.5
    )

    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    ax.spines["left"].set_linewidth(0.5)
    ax.spines["bottom"].set_linewidth(0.5)

# Turn off unused axes
for ax in axes[len(chrom_order):]:
    ax.axis("off")

# ============================================================
# Shared labels and note
# ============================================================

fig.text(
    0.5,
    0.04,
    "Chromosome position (Mb)",
    ha="center",
    fontsize=9
)

fig.text(
    0.04,
    0.5,
    "Mean FST",
    va="center",
    rotation="vertical",
    fontsize=9
)

fig.text(
    0.5,
    0.01,
    f"Dashed line: genome-wide mean FST = {genome_mean_fst:.3f}; labels shown only for candidates with local FST ≥ top 5% threshold ({label_threshold:.3f}).",
    ha="center",
    fontsize=7
)

plt.tight_layout(rect=[0.06, 0.06, 1, 0.98])

plt.savefig(
    out_png,
    dpi=600,
    bbox_inches="tight"
)

plt.savefig(
    out_pdf,
    bbox_inches="tight"
)

plt.close()

# ============================================================
# Save labeled-gene summary
# ============================================================

label_df = pd.DataFrame(label_summary)

label_df.to_csv(
    "maturity_candidates_labeled_highFST_only.tsv",
    sep="\t",
    index=False
)

print("Saved:", out_png)
print("Saved:", out_pdf)
print("Saved: maturity_candidates_labeled_highFST_only.tsv")

print("\nLabeled candidates:")
print(label_df)
