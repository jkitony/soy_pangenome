#!/usr/bin/env python3

import pandas as pd
import numpy as np

infile = "maturity_genes_genomewide_candidates.tsv"

out_all_named = "maturity_genes_named_candidates.tsv"
out_one_per_chr = "maturity_genes_one_per_chr.bed"
out_one_per_chr_table = "maturity_genes_one_per_chr.tsv"

df = pd.read_csv(infile, sep="\t", dtype=str).fillna("")

# Keep only rows with Preferred_name
df = df[
    ~df["Preferred_name"].isin(["", "-", "NA", "nan", "None"])
].copy()

# Convert numeric columns
df["score_num"] = pd.to_numeric(df["score"], errors="coerce")
df["evalue_num"] = pd.to_numeric(df["evalue"], errors="coerce")
df["start"] = pd.to_numeric(df["start"], errors="coerce").astype(int)
df["end"] = pd.to_numeric(df["end"], errors="coerce").astype(int)

# ------------------------------------------------------------
# Priority system: known maturity/photoperiod first,
# then hormone/height candidates, then broad B3/ARF candidates.
# ------------------------------------------------------------
priority = {
    "ELF3": 1,
    "GI": 1,
    "PHYA": 1,
    "CRY2": 2,
    "APRR2": 2,
    "GID1": 3,
    "GID1a": 3,
    "GA2ox3": 3,
    "IAA20": 4,
    "IAA32": 4,
    "ARF17": 5,
    "ARF8": 5,
    "ARF6": 5,
    "ARF11": 5,
    "RAV1": 6,
}

def assign_priority(name):
    if name in priority:
        return priority[name]
    if name.startswith("ARF"):
        return 5
    if name.startswith("IAA"):
        return 4
    return 9

df["priority"] = df["Preferred_name"].apply(assign_priority)

# Save all named candidates for inspection
df.sort_values(["chr", "priority", "score_num"], ascending=[True, True, False]).to_csv(
    out_all_named,
    sep="\t",
    index=False
)

# Pick one per chromosome:
# 1. lowest priority score
# 2. highest eggNOG score
# 3. lowest e-value
best = (
    df.sort_values(
        ["chr", "priority", "score_num", "evalue_num"],
        ascending=[True, True, False, True]
    )
    .groupby("chr", as_index=False)
    .first()
)

# Clean label
best["label"] = best["Preferred_name"]

# Save table
best.to_csv(out_one_per_chr_table, sep="\t", index=False)

# Save BED
best[["chr", "start", "end", "label"]].to_csv(
    out_one_per_chr,
    sep="\t",
    header=False,
    index=False
)

print("Saved:", out_all_named)
print("Saved:", out_one_per_chr_table)
print("Saved:", out_one_per_chr)

print("\nOne candidate per chromosome:")
print(best[["chr", "start", "end", "Preferred_name", "candidate_class", "score", "evalue"]])


