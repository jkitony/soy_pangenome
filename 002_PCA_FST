#!/usr/bin/env python3

import pandas as pd
import re

meta_file = "Meta_FINAL.csv"

def read_any_csv(fname):
    for enc in ["utf-8", "utf-8-sig", "cp1252", "latin1"]:
        try:
            return pd.read_csv(fname, encoding=enc)
        except UnicodeDecodeError:
            pass
    raise ValueError(f"Could not read {fname}")

def clean_text(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    if x in ["", "NA", "N/A", "nan", "None", "<NA>", "Unknown", "unknown"]:
        return pd.NA
    return x

def normalize_mg(x):
    if pd.isna(x):
        return pd.NA

    x = str(x).strip()
    x = re.sub(r"\s+", "", x)

    fixes = {
        "000": "MG_000",
        "00": "MG_00",
        "0": "MG_0",
        "I": "MG_I",
        "II": "MG_II",
        "III": "MG_III",
        "IV": "MG_IV",
        "V": "MG_V",
        "VI": "MG_VI",
        "VII": "MG_VII",
        "VIII": "MG_VIII",
        "IX": "MG_IX",
    }

    if x in fixes:
        return fixes[x]

    valid = [
        "MG_000", "MG_00", "MG_0", "MG_I", "MG_II",
        "MG_III", "MG_IV", "MG_V", "MG_VI",
        "MG_VII", "MG_VIII", "MG_IX"
    ]

    return x if x in valid else pd.NA

def assign_adaptation_group(mg):
    if pd.isna(mg):
        return pd.NA

    north = ["MG_000", "MG_00", "MG_0", "MG_I", "MG_II"]
    central = ["MG_III", "MG_IV"]
    south = ["MG_V", "MG_VI", "MG_VII", "MG_VIII", "MG_IX"]

    if mg in north:
        return "North_Early"
    elif mg in central:
        return "Central_Mid"
    elif mg in south:
        return "South_Late"
    else:
        return pd.NA

def write_keep(df, outfile):
    with open(outfile, "w") as f:
        for s in df["Sample"].dropna().astype(str).unique():
            f.write(f"{s}\t{s}\n")

meta = read_any_csv(meta_file)
meta.columns = meta.columns.str.strip()

required = ["Sample", "Species", "Germplasm_type", "Maturity_group"]
for col in required:
    if col not in meta.columns:
        raise ValueError(f"Missing column: {col}")

for col in required:
    meta[col] = meta[col].apply(clean_text)

meta["Maturity_group"] = meta["Maturity_group"].apply(normalize_mg)
meta["Adaptation_group"] = meta["Maturity_group"].apply(assign_adaptation_group)

meta = meta.drop_duplicates(subset=["Sample"]).copy()

# Adaptation PCA: only G.max with known maturity group
adapt = meta[
    (meta["Species"] == "G.max") &
    (meta["Maturity_group"].notna()) &
    (meta["Adaptation_group"].notna())
].copy()

# Extreme-only adaptation PCA: North_Early vs South_Late
adapt_extreme = adapt[
    adapt["Adaptation_group"].isin(["North_Early", "South_Late"])
].copy()

write_keep(adapt, "Adaptation_allMG.keep")
write_keep(adapt_extreme, "Adaptation_extreme.keep")

meta.to_csv("Meta_FINAL.cleaned_for_PCA.csv", index=False)

print("Done preparing PCA groups.")
print("\nAll adaptation MG samples:")
print(adapt["Maturity_group"].value_counts().sort_index())

print("\nAdaptation groups:")
print(adapt["Adaptation_group"].value_counts())

print("\nExtreme groups only:")
print(adapt_extreme["Adaptation_group"].value_counts())
