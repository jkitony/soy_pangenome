#!/bin/bash
set -euo pipefail

VCF="soy.snp.bi.filt.vcf.gz"
OUTDIR="Adaptation_PCA"

mkdir -p "${OUTDIR}"

run_pca () {
    NAME=$1
    KEEP=$2

    echo "Running PCA for ${NAME}"

    plink --vcf "${VCF}" \
        --allow-extra-chr \
        --double-id \
        --keep "${KEEP}" \
        --make-bed \
        --out "${OUTDIR}/${NAME}"

    plink --bfile "${OUTDIR}/${NAME}" \
        --indep-pairwise 50 5 0.2 \
        --out "${OUTDIR}/${NAME}"

    plink --bfile "${OUTDIR}/${NAME}" \
        --extract "${OUTDIR}/${NAME}.prune.in" \
        --pca 10 \
        --out "${OUTDIR}/${NAME}"
}

run_pca "Adaptation_allMG" "Adaptation_allMG.keep"
run_pca "Adaptation_extreme" "Adaptation_extreme.keep"

echo "Done."
