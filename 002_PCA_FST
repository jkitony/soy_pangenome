#!/usr/bin/env python3

import pandas as pd
import re

ann = "/data1/jkitony/soybean/snp_selection_workflow/06_eggnog/background/Wm82a5_background.emapper.annotations"
gff = "Wm82a5.gene_models_main.renamed.gff3"

out_hits = "maturity_gene_candidates_from_background_eggnog.tsv"
out_coord = "candidate_maturity_genes_coordinates.tsv"

# -------------------------
# Read eggNOG annotation
# -------------------------
df = pd.read_csv(
    ann,
    sep="\t",
    comment="#",
    header=None,
    dtype=str
).fillna("")

cols = [
    "query", "seed_ortholog", "evalue", "score", "eggNOG_OGs",
    "max_annot_lvl", "COG_category", "Description", "Preferred_name",
    "GOs", "EC", "KEGG_ko", "KEGG_Pathway", "KEGG_Module",
    "KEGG_Reaction", "KEGG_rclass", "BRITE", "KEGG_TC",
    "CAZy", "BiGG_Reaction", "PFAMs"
]

df = df.iloc[:, :len(cols)]
df.columns = cols

df["gene_id"] = df["query"].str.replace(r"\.1$", "", regex=True)
df["search"] = df.astype(str).agg(" ".join, axis=1)

# -------------------------
# Candidate matching rules
# -------------------------
rules = {
    "E1_like_B3_Chr06": {
        "chr": "Chr06",
        "patterns": ["B3", "AP2 ERF and B3", "B3 domain"]
    },
    "E2_GIGANTEA_Chr10": {
        "chr": "Chr10",
        "patterns": ["GIGANTEA", "GI"]
    },
    "E3_PHYA_Chr19": {
        "chr": "Chr19",
        "patterns": ["PHYA", "phytochrome"]
    },
    "E4_PHYA_Chr20": {
        "chr": "Chr20",
        "patterns": ["PHYA", "phytochrome"]
    },
    "J_ELF3_Chr04": {
        "chr": "Chr04",
        "patterns": ["ELF3", "EARLY FLOWERING"]
    },
    "Tof11_PRR_Chr11": {
        "chr": "Chr11",
        "patterns": ["PRR", "pseudo-response", "response regulator", "APRR"]
    },
    "Tof12_PRR_Chr12": {
        "chr": "Chr12",
        "patterns": ["PRR", "pseudo-response", "response regulator", "APRR"]
    },
}

hits = []

for label, cfg in rules.items():
    chrom = cfg["chr"]
    pattern = "|".join([re.escape(p) for p in cfg["patterns"]])

    sub = df[
        df["gene_id"].str.contains(chrom, na=False) &
        df["search"].str.contains(pattern, case=False, na=False)
    ].copy()

    sub["candidate_label"] = label
    sub["expected_chr"] = chrom

    hits.append(sub)

hits = pd.concat(hits, ignore_index=True)
hits.to_csv(out_hits, sep="\t", index=False)

print("Candidate hits by rule:")
print(hits["candidate_label"].value_counts())

# -------------------------
# Read GFF coordinates
# -------------------------
gff_records = []

with open(gff) as f:
    for line in f:
        if line.startswith("#"):
            continue

        parts = line.rstrip().split("\t")
        if len(parts) < 9:
            continue

        chrom, source, feature, start, end, score, strand, phase, attrs = parts

        if feature != "gene":
            continue

        m = re.search(r"ID=([^;]+)", attrs)
        if not m:
            continue

        gene_id = m.group(1)

        gff_records.append({
            "gene_id": gene_id,
            "chr": chrom,
            "start": int(start),
            "end": int(end),
            "strand": strand
        })

gff_df = pd.DataFrame(gff_records)

# -------------------------
# Merge coordinates
# -------------------------
hits_coord = hits.merge(
    gff_df,
    on="gene_id",
    how="left"
)

# Keep clean coordinate table
coord = hits_coord[
    [
        "candidate_label",
        "gene_id",
        "chr",
        "start",
        "end",
        "strand",
        "Preferred_name",
        "Description",
        "PFAMs",
        "seed_ortholog",
        "evalue",
        "score"
    ]
].copy()

coord.to_csv(out_coord, sep="\t", index=False)

print("\nSaved:")
print(out_hits)
print(out_coord)

print("\nTop candidates:")
print(coord.sort_values(["candidate_label", "evalue"]).head(50))

