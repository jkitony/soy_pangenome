#!/usr/bin/env python3

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path

infile = "tables/Cultivar_vs_Landrace_selection_windows.tsv"
outdir = Path("plots")
outdir.mkdir(exist_ok=True)

df = pd.read_csv(infile, sep="\t")

# -------------------------
# Clean chromosome names and ordering
# -------------------------
def chr_key(x):
    x = str(x)
    x2 = x.replace("Chr", "").replace("chr", "")
    try:
        return int(x2)
    except ValueError:
        return x2

chroms = sorted(df["CHROM"].dropna().unique(), key=chr_key)

# cumulative coordinates
offset = 0
xticks = []
xlabels = []
frames = []

for i, chrom in enumerate(chroms):
    sub = df[df["CHROM"] == chrom].copy().sort_values("MIDPOINT")
    if sub.empty:
        continue

    sub["BP_CUM"] = sub["MIDPOINT"] + offset
    frames.append(sub)

    xticks.append((sub["BP_CUM"].min() + sub["BP_CUM"].max()) / 2)
    xlabels.append(str(chrom))

    offset = sub["BP_CUM"].max()

plotdf = pd.concat(frames, ignore_index=True)

# thresholds
fst_thr = plotdf["WEIGHTED_FST"].dropna().quantile(0.95)
pir_thr = plotdf["LOG2_PI_RATIO_LR_vs_CL"].replace([np.inf, -np.inf], np.nan).dropna().quantile(0.95)

# alternating colors
chrom_to_color = {chrom: ("#4e79a7" if i % 2 == 0 else "#f28e2b") for i, chrom in enumerate(chroms)}
plotdf["COLOR"] = plotdf["CHROM"].map(chrom_to_color)

# -------------------------
# Plot 1: FST
# -------------------------
plt.figure(figsize=(14, 4))
for chrom in chroms:
    sub = plotdf[plotdf["CHROM"] == chrom]
    plt.scatter(sub["BP_CUM"], sub["WEIGHTED_FST"], s=8, c=sub["COLOR"], alpha=0.8)

plt.axhline(fst_thr, linestyle="--", linewidth=1)
plt.xticks(xticks, xlabels, rotation=0)
plt.ylabel("Weighted FST")
plt.xlabel("Chromosome")
plt.title("Cultivar vs Landrace selection scan: FST")
plt.tight_layout()
plt.savefig(outdir / "Cultivar_vs_Landrace_FST_manhattan.png", dpi=600)
plt.savefig(outdir / "Cultivar_vs_Landrace_FST_manhattan.pdf")
plt.close()

# -------------------------
# Plot 2: log2 pi ratio
# -------------------------
plt.figure(figsize=(14, 4))
for chrom in chroms:
    sub = plotdf[plotdf["CHROM"] == chrom]
    plt.scatter(sub["BP_CUM"], sub["LOG2_PI_RATIO_LR_vs_CL"], s=8, c=sub["COLOR"], alpha=0.8)

plt.axhline(pir_thr, linestyle="--", linewidth=1)
plt.xticks(xticks, xlabels, rotation=0)
plt.ylabel("log2(piLandrace / piCultivar)")
plt.xlabel("Chromosome")
plt.title("Cultivar vs Landrace selection scan: diversity reduction")
plt.tight_layout()
plt.savefig(outdir / "Cultivar_vs_Landrace_log2PiRatio_manhattan.png", dpi=600)
plt.savefig(outdir / "Cultivar_vs_Landrace_log2PiRatio_manhattan.pdf")
plt.close()

# -------------------------
# Plot 3: combined stacked figure
# -------------------------
fig, axes = plt.subplots(2, 1, figsize=(14, 7), sharex=True)

# FST
for chrom in chroms:
    sub = plotdf[plotdf["CHROM"] == chrom]
    axes[0].scatter(sub["BP_CUM"], sub["WEIGHTED_FST"], s=8, c=sub["COLOR"], alpha=0.8)
axes[0].axhline(fst_thr, linestyle="--", linewidth=1)
axes[0].set_ylabel("Weighted FST")
axes[0].set_title("Cultivar vs Landrace selection signatures")

# pi ratio
for chrom in chroms:
    sub = plotdf[plotdf["CHROM"] == chrom]
    axes[1].scatter(sub["BP_CUM"], sub["LOG2_PI_RATIO_LR_vs_CL"], s=8, c=sub["COLOR"], alpha=0.8)
axes[1].axhline(pir_thr, linestyle="--", linewidth=1)
axes[1].set_ylabel("log2(piLR/piCL)")
axes[1].set_xlabel("Chromosome")
axes[1].set_xticks(xticks)
axes[1].set_xticklabels(xlabels)

plt.tight_layout()
plt.savefig(outdir / "Cultivar_vs_Landrace_combined_selection_manhattan.png", dpi=600)
plt.savefig(outdir / "Cultivar_vs_Landrace_combined_selection_manhattan.pdf")
plt.close()

# -------------------------
# candidate windows only
# -------------------------
cand = plotdf[plotdf["CANDIDATE_BOTH"] == True].copy()
cand.to_csv(outdir / "Cultivar_vs_Landrace_candidate_windows_for_plot.tsv", sep="\t", index=False)

print("Plots saved to:", outdir)
print("Candidate windows:", len(cand))
