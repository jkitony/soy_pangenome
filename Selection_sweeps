#!/usr/bin/env python3

import pandas as pd

META = "Meta.csv"
VCF_SAMPLES = "vcf_samples.txt"

def clean(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    if x in {"", "NA", "N/A", "nan", "None", "<NA>"}:
        return pd.NA
    return x

def norm_ecotype(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    fixes = {
        "cultivar": "Cultivar",
        "landrace": "Landrace",
        "Cultivar": "Cultivar",
        "Landrace": "Landrace",
    }
    return fixes.get(x, x)

try:
    meta = pd.read_csv(META, encoding="utf-8")
except UnicodeDecodeError:
    meta = pd.read_csv(META, encoding="latin1")
meta.columns = meta.columns.str.strip()

meta["Sample"] = meta["Sample"].apply(clean)
meta["Ecotype"] = meta["Ecotype"].apply(clean).apply(norm_ecotype)

meta = meta.dropna(subset=["Sample", "Ecotype"]).drop_duplicates(subset=["Sample"])

with open(VCF_SAMPLES) as f:
    vcf_samples = {line.strip() for line in f if line.strip()}

meta["in_vcf"] = meta["Sample"].isin(vcf_samples)

imp = meta[meta["in_vcf"] & meta["Ecotype"].isin(["Cultivar", "Landrace"])].copy()

cultivar = imp[imp["Ecotype"] == "Cultivar"]["Sample"].sort_values().tolist()
landrace = imp[imp["Ecotype"] == "Landrace"]["Sample"].sort_values().tolist()

with open("Cultivar.txt", "w") as f:
    for s in cultivar:
        f.write(f"{s}\n")

with open("Landrace.txt", "w") as f:
    for s in landrace:
        f.write(f"{s}\n")

imp.to_csv("Improvement_samples_in_vcf.tsv", sep="\t", index=False)

print("Cultivar in VCF:", len(cultivar))
print("Landrace in VCF:", len(landrace))
print("\nCounts from intersected metadata:")
print(imp["Ecotype"].value_counts())

