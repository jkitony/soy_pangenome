#!/usr/bin/env python3

import pandas as pd
import numpy as np

fst_file = "fst/Cultivar_vs_Landrace.windowed.weir.fst"
cult_file = "pi/Cultivar.windowed.pi"
land_file = "pi/Landrace.windowed.pi"
out_file = "tables/Cultivar_vs_Landrace_selection_windows.tsv"

# -------------------------
# Read files
# -------------------------
fst = pd.read_csv(fst_file, sep=r"\s+")
cult = pd.read_csv(cult_file, sep=r"\s+")
land = pd.read_csv(land_file, sep=r"\s+")

# -------------------------
# Clean columns
# -------------------------
fst.columns = [c.strip() for c in fst.columns]
cult.columns = [c.strip() for c in cult.columns]
land.columns = [c.strip() for c in land.columns]

# Standardize names
fst = fst.rename(columns={
    "CHROM": "CHROM",
    "BIN_START": "BIN_START",
    "BIN_END": "BIN_END",
    "N_VARIANTS": "N_VARIANTS_FST",
    "WEIGHTED_FST": "WEIGHTED_FST",
    "MEAN_FST": "MEAN_FST"
})

cult = cult.rename(columns={
    "CHROM": "CHROM",
    "BIN_START": "BIN_START",
    "BIN_END": "BIN_END",
    "N_VARIANTS": "N_VARIANTS_CULTIVAR",
    "PI": "PI_CULTIVAR"
})

land = land.rename(columns={
    "CHROM": "CHROM",
    "BIN_START": "BIN_START",
    "BIN_END": "BIN_END",
    "N_VARIANTS": "N_VARIANTS_LANDRACE",
    "PI": "PI_LANDRACE"
})

# -------------------------
# Merge
# -------------------------
df = fst.merge(
    cult[["CHROM", "BIN_START", "BIN_END", "PI_CULTIVAR", "N_VARIANTS_CULTIVAR"]],
    on=["CHROM", "BIN_START", "BIN_END"],
    how="outer"
).merge(
    land[["CHROM", "BIN_START", "BIN_END", "PI_LANDRACE", "N_VARIANTS_LANDRACE"]],
    on=["CHROM", "BIN_START", "BIN_END"],
    how="outer"
)

# midpoint
df["MIDPOINT"] = ((df["BIN_START"] + df["BIN_END"]) / 2).astype(float)

# numeric cleanup
for col in ["WEIGHTED_FST", "MEAN_FST", "PI_CULTIVAR", "PI_LANDRACE"]:
    if col in df.columns:
        df[col] = pd.to_numeric(df[col], errors="coerce")

# remove negative FST if desired
df.loc[df["WEIGHTED_FST"] < 0, "WEIGHTED_FST"] = 0

# pi ratio and log2 ratio
df["PI_RATIO_LANDRACE_vs_CULTIVAR"] = df["PI_LANDRACE"] / df["PI_CULTIVAR"]
df["LOG2_PI_RATIO_LR_vs_CL"] = np.log2(df["PI_RATIO_LANDRACE_vs_CULTIVAR"])

# -------------------------
# Percentile thresholds
# -------------------------
fst_thr = df["WEIGHTED_FST"].dropna().quantile(0.95)
pir_thr = df["LOG2_PI_RATIO_LR_vs_CL"].replace([np.inf, -np.inf], np.nan).dropna().quantile(0.95)

df["TOP5_FST"] = df["WEIGHTED_FST"] >= fst_thr
df["TOP5_LOG2_PI_RATIO"] = df["LOG2_PI_RATIO_LR_vs_CL"] >= pir_thr
df["CANDIDATE_BOTH"] = df["TOP5_FST"] & df["TOP5_LOG2_PI_RATIO"]

# order columns
cols = [
    "CHROM", "BIN_START", "BIN_END", "MIDPOINT",
    "N_VARIANTS_FST", "WEIGHTED_FST", "MEAN_FST",
    "N_VARIANTS_CULTIVAR", "PI_CULTIVAR",
    "N_VARIANTS_LANDRACE", "PI_LANDRACE",
    "PI_RATIO_LANDRACE_vs_CULTIVAR", "LOG2_PI_RATIO_LR_vs_CL",
    "TOP5_FST", "TOP5_LOG2_PI_RATIO", "CANDIDATE_BOTH"
]
cols = [c for c in cols if c in df.columns]
df = df[cols].sort_values(["CHROM", "BIN_START"])

df.to_csv(out_file, sep="\t", index=False)

# thresholds summary
with open("tables/Cultivar_vs_Landrace_thresholds.txt", "w") as f:
    f.write(f"95th percentile WEIGHTED_FST\t{fst_thr}\n")
    f.write(f"95th percentile LOG2_PI_RATIO_LR_vs_CL\t{pir_thr}\n")
    f.write(f"Candidate windows (both)\t{df['CANDIDATE_BOTH'].sum()}\n")

print("Done.")
print(f"Saved: {out_file}")
print(f"FST 95th percentile: {fst_thr:.6f}")
print(f"log2(pi ratio) 95th percentile: {pir_thr:.6f}")
print(f"Candidate windows: {df['CANDIDATE_BOTH'].sum()}")
