#!/usr/bin/env python3

import os
import re
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

OUTDIR = "XPCLRS/annotation"
ANNOT_TABLE = f"{OUTDIR}/xpclr_top1_functional_annotation_table.tsv"

GO_FILES = {
    "domestication": f"{OUTDIR}/domestication_GO_enrichment_real_background.tsv",
    "improvement": f"{OUTDIR}/improvement_GO_enrichment_real_background.tsv",
}

# Remove clearly non-plant/cross-kingdom artifact terms from manuscript table/plots
EXCLUDE_KEYWORDS = [
    "blood", "arterial", "angiogenesis", "vessel endothelial",
    "mating projection", "fungal-type", "septum digestion",
    "primary cell septum", "division septum",
    "animal", "embryonic placenta", "neuron", "muscle",
]

# Keep terms with plant-relevant biology
KEEP_KEYWORDS = [
    "root", "seed", "flower", "floral", "germination", "dormancy",
    "cell wall", "glucan", "pectin", "cellulose", "lignin", "xylan",
    "shatter", "dehiscence", "abscission",
    "defense", "immune", "biotic", "pathogen",
    "oxidative", "reactive oxygen", "redox",
    "abiotic", "salt", "drought", "water", "cold", "heat",
    "transport", "transmembrane", "ion", "metal", "manganese",
    "photosynthesis", "chlorophyll", "carbon", "carbohydrate",
    "lipid", "fatty acid", "oil",
    "hormone", "auxin", "gibberellin", "abscisic acid", "ethylene",
    "jasmonic", "salicylic", "cytokinin",
    "symbiosome", "peribacteroid", "bacteroid", "nodulation", "nitrogen",
    "cell division", "cell cycle", "cytokinesis",
    "transcription", "dna-binding", "kinase", "phosphorylation",
    "membrane", "vacuolar", "plasma membrane",
    "glucosidase", "glycoside", "glucosinolate",
    "methyltransferase", "oxidoreductase",
]

def is_plant_relevant(term):
    if pd.isna(term):
        return False
    t = str(term).lower()

    if t == "na":
        return False

    if any(k in t for k in EXCLUDE_KEYWORDS):
        return False

    return any(k in t for k in KEEP_KEYWORDS)

def functional_interpretation(term):
    t = str(term).lower()

    if any(k in t for k in ["symbiosome", "peribacteroid", "bacteroid", "nodulation", "nitrogen"]):
        return "Legume-rhizobia symbiosis and biological nitrogen fixation"

    if any(k in t for k in ["cell wall", "glucan", "pectin", "cellulose", "lignin", "xylan"]):
        return "Cell wall remodeling related to growth, architecture, and pod/seed traits"

    if any(k in t for k in ["seed", "germination", "dormancy"]):
        return "Seed development, dormancy, and domestication-related seed traits"

    if any(k in t for k in ["flower", "floral", "photoperiod", "circadian"]):
        return "Flowering time, maturity, and adaptation"

    if any(k in t for k in ["defense", "immune", "pathogen", "biotic"]):
        return "Defense response and biotic stress adaptation"

    if any(k in t for k in ["oxidative", "reactive oxygen", "redox", "oxidoreductase"]):
        return "Oxidative stress response and redox homeostasis"

    if any(k in t for k in ["transport", "transmembrane", "ion", "metal", "manganese"]):
        return "Membrane transport, nutrient uptake, and ion homeostasis"

    if any(k in t for k in ["lipid", "fatty acid", "oil"]):
        return "Lipid metabolism and seed composition"

    if any(k in t for k in ["photosynthesis", "chlorophyll", "carbon", "carbohydrate"]):
        return "Carbon metabolism, photosynthesis, and biomass production"

    if any(k in t for k in ["hormone", "auxin", "gibberellin", "abscisic acid", "ethylene", "jasmonic", "salicylic"]):
        return "Hormone signaling controlling growth, stress response, and adaptation"

    if any(k in t for k in ["cell division", "cell cycle", "cytokinesis"]):
        return "Cell proliferation and developmental growth"

    if any(k in t for k in ["transcription", "dna-binding"]):
        return "Transcriptional regulation of development and adaptation"

    if any(k in t for k in ["kinase", "phosphorylation"]):
        return "Signaling pathways involved in growth and stress response"

    if any(k in t for k in ["glucosidase", "glycoside", "glucosinolate"]):
        return "Secondary metabolism, defense, and cell wall/metabolic remodeling"

    return "Plant-relevant selected function"

def make_bubble(df, scan, outfile_prefix, topn=20):
    plot_df = df.copy()
    plot_df = plot_df.sort_values(["FDR", "P_value"]).head(topn)
    plot_df = plot_df.sort_values("minus_log10_FDR")

    plot_df["Label"] = plot_df["GO_term"] + " (" + plot_df["GO"] + ")"

    plt.figure(figsize=(10, max(6, 0.35 * len(plot_df))))

    sc = plt.scatter(
        plot_df["Gene_ratio"],
        plot_df["Label"],
        s=plot_df["Selected_with_GO"] * 12,
        c=plot_df["minus_log10_FDR"],
        alpha=0.85
    )

    plt.colorbar(sc, label="-log10(FDR)")
    plt.xlabel("Gene ratio")
    plt.ylabel("")
    plt.title(f"Plant-relevant GO enrichment: {scan.capitalize()}")
    plt.tight_layout()

    plt.savefig(f"{outfile_prefix}.png", dpi=300)
    plt.savefig(f"{outfile_prefix}.pdf")
    plt.close()

def extract_genes_for_go_terms():
    annot = pd.read_csv(ANNOT_TABLE, sep="\t")

    targets = {
        "symbiosome_peribacteroid": ["GO:0043659", "GO:0043661", "GO:0043660"],
    }

    for name, go_ids in targets.items():
        pattern = "|".join(go_ids)

        sub = annot[
            annot["GO_terms"].fillna("").str.contains(pattern, regex=True)
        ].copy()

        out = f"{OUTDIR}/{name}_candidate_genes.tsv"
        sub.to_csv(out, sep="\t", index=False)

        gene_out = f"{OUTDIR}/{name}_gene_ids.txt"
        sub["Gene_ID"].dropna().drop_duplicates().sort_values().to_csv(
            gene_out, index=False, header=False
        )

        print(f"Saved genes for {name}: {out}")
        print(f"Saved gene IDs for {name}: {gene_out}")
        print(f"Number of genes: {sub['Gene_ID'].nunique()}")

all_curated = []

for scan, infile in GO_FILES.items():
    df = pd.read_csv(infile, sep="\t")

    df = df[df["GO_term"].notna()]
    df = df[df["GO_term"] != "NA"]
    df = df[df["GO_category"].isin(["BP", "MF", "CC"])]
    df = df[df["FDR"] < 0.05].copy()

    df["Plant_relevant"] = df["GO_term"].apply(is_plant_relevant)
    df = df[df["Plant_relevant"]].copy()

    df["Functional_interpretation"] = df["GO_term"].apply(functional_interpretation)

    df = df.sort_values(["FDR", "P_value"])

    cols = [
        "GO_category",
        "GO_term",
        "GO",
        "Functional_interpretation",
        "Selected_with_GO",
        "Selected_total",
        "Background_with_GO",
        "Background_total",
        "Odds_ratio",
        "P_value",
        "FDR",
        "minus_log10_FDR",
        "Gene_ratio",
        "Bg_ratio",
        "Sweep_type",
    ]

    cols = [c for c in cols if c in df.columns]
    df = df[cols]

    out_table = f"{OUTDIR}/{scan}_GO_enrichment_curated_plant_relevant.tsv"
    df.to_csv(out_table, sep="\t", index=False)

    make_bubble(
        df,
        scan,
        f"{OUTDIR}/{scan}_GO_enrichment_curated_plant_relevant_bubble"
    )

    all_curated.append(df)

    print(f"\n{scan.capitalize()}:")
    print(f"Saved curated table: {out_table}")
    print(f"Terms retained: {len(df)}")
    print(df.head(10)[["GO_category", "GO_term", "GO", "Selected_with_GO", "FDR"]])

combined = pd.concat(all_curated, ignore_index=True)
combined.to_csv(
    f"{OUTDIR}/combined_GO_enrichment_curated_plant_relevant.tsv",
    sep="\t",
    index=False
)

extract_genes_for_go_terms()

print("\nDone.")
