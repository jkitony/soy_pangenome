#!/usr/bin/env bash
set -euo pipefail

PROTEIN_FA="Wm82a5.protein.renamed.faa"
ANN_DIR="XPCLRS_SV/annotation"

echo "Using protein FASTA:"
echo "${PROTEIN_FA}"

for scan in domestication improvement
do
    echo
    echo "======================================"
    echo "Processing ${scan} SV sweep genes"
    echo "======================================"

    GENE_IDS="${ANN_DIR}/${scan}.SV.top1.gene_ids.txt"

    PATTERNS="${ANN_DIR}/${scan}.SV.top1.protein_patterns.txt"

    ALL_PROTEINS="${ANN_DIR}/${scan}.SV.top1.proteins.all_isoforms.fa"

    ONE_ISOFORM="${ANN_DIR}/${scan}.SV.top1.proteins.one_isoform.fa"

    if [[ ! -s ${GENE_IDS} ]]; then
        echo "ERROR: Missing ${GENE_IDS}"
        exit 1
    fi

    echo "1. Making gene search patterns..."

    awk '{print "gene="$1}' ${GENE_IDS} \
        > ${PATTERNS}

    echo "2. Extracting all matching protein isoforms..."

    seqkit grep \
        -n \
        -r \
        -f ${PATTERNS} \
        ${PROTEIN_FA} \
        > ${ALL_PROTEINS}

    echo "3. Keeping one isoform per gene..."

    python - ${ALL_PROTEINS} ${ONE_ISOFORM} << 'PY'
import sys
import re

infile = sys.argv[1]
outfile = sys.argv[2]

seen = set()
write = False

with open(infile) as fin, open(outfile, "w") as fout:

    for line in fin:

        if line.startswith(">"):

            header = line.strip()

            m = re.search(r"gene=([^\s]+)", header)

            if not m:
                write = False
                continue

            gene = m.group(1)

            if gene in seen:
                write = False
            else:
                seen.add(gene)
                write = True
                fout.write(line)

        else:
            if write:
                fout.write(line)
PY

    echo
    echo "${scan} SV sweep genes:"
    wc -l ${GENE_IDS}

    echo
    echo "${scan} all isoform proteins:"
    grep -c "^>" ${ALL_PROTEINS} || true

    echo
    echo "${scan} one-isoform proteins:"
    grep -c "^>" ${ONE_ISOFORM} || true

done

echo
echo "Done."
EOF

chmod +x 04_extract_sv_sweep_proteins_v5.sh
