#!/usr/bin/env python3
import pandas as pd
import matplotlib.pyplot as plt
import re
from pathlib import Path

def chr_sort_key(chrom):
    m = re.search(r"(\d+)", str(chrom))
    return int(m.group(1)) if m else 999

def make_plot(infile, outfile_prefix, title):
    df = pd.read_csv(infile, sep="\t")
    df["xpclr"] = pd.to_numeric(df["xpclr"], errors="coerce")
    df["start"] = pd.to_numeric(df["start"], errors="coerce")
    df["stop"] = pd.to_numeric(df["stop"], errors="coerce")
    df = df.dropna(subset=["chrom", "start", "stop", "xpclr"])
    df["midpoint"] = (df["start"] + df["stop"]) / 2

    pieces, ticks, labels = [], [], []
    offset = 0

    for chrom in sorted(df["chrom"].unique(), key=chr_sort_key):
        sub = df[df["chrom"] == chrom].sort_values("midpoint").copy()
        sub["BPcum"] = sub["midpoint"] + offset
        pieces.append(sub)
        ticks.append(sub["BPcum"].median())
        labels.append(str(chrom).replace("Chr", ""))
        offset = sub["BPcum"].max()

    plot_df = pd.concat(pieces, ignore_index=True)
    thr95 = plot_df["xpclr"].quantile(0.95)
    thr99 = plot_df["xpclr"].quantile(0.99)

    top1 = plot_df[plot_df["xpclr"] >= thr99].copy()
    top1.to_csv(f"{outfile_prefix}.top1.tsv", sep="\t", index=False)

    plt.figure(figsize=(16, 5))
    for chrom in sorted(plot_df["chrom"].unique(), key=chr_sort_key):
        sub = plot_df[plot_df["chrom"] == chrom]
        plt.scatter(sub["BPcum"], sub["xpclr"], s=6, alpha=0.75)

    plt.axhline(thr99, linestyle="--", linewidth=1, label=f"Top 1% = {thr99:.3f}")
    if thr95 > 0:
        plt.axhline(thr95, linestyle=":", linewidth=1, label=f"Top 5% = {thr95:.3f}")

    plt.xticks(ticks, labels, fontsize=8)
    plt.xlabel("Chromosome")
    plt.ylabel("SV XP-CLR")
    plt.title(title)
    plt.legend(frameon=False)
    plt.tight_layout()
    plt.savefig(f"{outfile_prefix}.png", dpi=300)
    plt.savefig(f"{outfile_prefix}.pdf")
    plt.close()

    print(title)
    print("Windows:", len(plot_df))
    print("Top1 threshold:", thr99)
    print("Top5 threshold:", thr95)
    print("Top1 windows:", len(top1))
    print("Max:", plot_df["xpclr"].max())

Path("XPCLRS_SV/plots").mkdir(parents=True, exist_ok=True)

