#!/usr/bin/env python3

import gzip
import re
import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

VCF = "soy.SVmarkers.sorted.vcf.gz"
OUTDIR = "qc/sv_qc_plots"

os.makedirs(OUTDIR, exist_ok=True)

rows = []

def parse_info(info):
    d = {}
    for item in info.split(";"):
        if "=" in item:
            k, v = item.split("=", 1)
            d[k] = v
        else:
            d[item] = True
    return d

def infer_svtype(vid, ref, alt, info):
    svtype = info.get("SVTYPE", "")

    if svtype:
        return svtype.upper()

    text = f"{vid} {alt}".lower()

    if "del" in text:
        return "DEL"
    if "ins" in text:
        return "INS"

    if len(ref) > len(alt):
        return "DEL"
    if len(alt) > len(ref):
        return "INS"

    return "OTHER"

def infer_svlen(ref, alt, info):
    for key in ["SVLEN", "LEN", "END"]:
        if key in info:
            try:
                if key == "END":
                    return abs(int(info[key]) - pos + 1)
                return abs(int(str(info[key]).split(",")[0]))
            except Exception:
                pass

    if alt.startswith("<") and alt.endswith(">"):
        return np.nan

    return abs(len(alt) - len(ref))

def allele_frequency(format_field, sample_fields):
    keys = format_field.split(":")
    try:
        gt_index = keys.index("GT")
    except ValueError:
        return np.nan

    alt_count = 0
    allele_count = 0

    for sample in sample_fields:
        vals = sample.split(":")
        if gt_index >= len(vals):
            continue

        gt = vals[gt_index]

        if gt in ["./.", ".|.", "."]:
            continue

        alleles = re.split(r"[\/|]", gt)

        for a in alleles:
            if a == ".":
                continue
            allele_count += 1
            if a != "0":
                alt_count += 1

    if allele_count == 0:
        return np.nan

    return alt_count / allele_count

with gzip.open(VCF, "rt") as f:
    for line in f:
        if line.startswith("#"):
            continue

        parts = line.rstrip("\n").split("\t")

        chrom = parts[0]
        pos = int(parts[1])
        vid = parts[2]
        ref = parts[3]
        alt = parts[4]
        info = parse_info(parts[7])
        fmt = parts[8]
        samples = parts[9:]

        svtype = infer_svtype(vid, ref, alt, info)
        svlen = infer_svlen(ref, alt, info)
        af = allele_frequency(fmt, samples)

        rows.append({
            "CHROM": chrom,
            "POS": pos,
            "ID": vid,
            "SVTYPE": svtype,
            "SVLEN": svlen,
            "AF": af
        })

df = pd.DataFrame(rows)

out_table = f"{OUTDIR}/sv_qc_summary_table.tsv"
df.to_csv(out_table, sep="\t", index=False)

print("Saved:", out_table)
print(df["SVTYPE"].value_counts(dropna=False))
print("Total variants:", len(df))
print("Variants with AF:", df["AF"].notna().sum())
print("Variants with SVLEN:", df["SVLEN"].notna().sum())

# 1. Insertion vs deletion counts
counts = df[df["SVTYPE"].isin(["INS", "DEL"])]["SVTYPE"].value_counts()

plt.figure(figsize=(5, 4))
plt.bar(counts.index, counts.values)
plt.ylabel("Number of SV markers")
plt.xlabel("SV type")
plt.title("Insertion vs deletion counts")
plt.tight_layout()
plt.savefig(f"{OUTDIR}/insertion_vs_deletion_counts.png", dpi=300)
plt.savefig(f"{OUTDIR}/insertion_vs_deletion_counts.pdf")
plt.close()

# 2. SV size distribution
size_df = df[
    df["SVTYPE"].isin(["INS", "DEL"]) &
    df["SVLEN"].notna() &
    (df["SVLEN"] > 0)
].copy()

size_df["log10_SVLEN"] = np.log10(size_df["SVLEN"])

plt.figure(figsize=(7, 5))
for svtype in ["INS", "DEL"]:
    sub = size_df[size_df["SVTYPE"] == svtype]
    if len(sub) > 0:
        plt.hist(sub["log10_SVLEN"], bins=50, alpha=0.6, label=svtype)

plt.xlabel("log10(SV size in bp)")
plt.ylabel("Number of SV markers")
plt.title("SV size distribution")
plt.legend(frameon=False)
plt.tight_layout()
plt.savefig(f"{OUTDIR}/sv_size_distribution_log10.png", dpi=300)
plt.savefig(f"{OUTDIR}/sv_size_distribution_log10.pdf")
plt.close()

# 3. Allele frequency spectrum
af_df = df[df["AF"].notna()].copy()

plt.figure(figsize=(7, 5))
plt.hist(af_df["AF"], bins=50)
plt.xlabel("Alternate allele frequency")
plt.ylabel("Number of SV markers")
plt.title("Allele frequency spectrum of SV markers")
plt.tight_layout()
plt.savefig(f"{OUTDIR}/sv_allele_frequency_spectrum.png", dpi=300)
plt.savefig(f"{OUTDIR}/sv_allele_frequency_spectrum.pdf")
plt.close()

print("\nDone. Plots saved in:", OUTDIR)
