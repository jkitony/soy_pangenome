with open(meta, newline="", encoding="latin1") as f:
    reader = csv.DictReader(f)
    print("Detected columns:")
    print(reader.fieldnames)
    for row in reader:
        pi = row["PI"].strip()
        ecotype = row["Ecotype"].strip()
        if ecotype in samples and pi and pi != "NA":
            samples[ecotype].add(pi)
for group, outfile in groups.items():
    with open(outfile, "w") as out:
        for x in sorted(samples[group]):
            out.write(x + "\n")
    print(group, len(samples[group]), outfile)
