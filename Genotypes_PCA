#!/usr/bin/env python3

import os
import re
import pandas as pd
import matplotlib.pyplot as plt

META_FILE = "Meta.cleaned.csv"
PCA_DIR = "Separate_PCA"
OUT_ROOT = "Separate_PCA_Plots"

FIG_W = 4
FIG_H = 4
DPI = 600
POINT_SIZE = 18
ALPHA = 0.9
EDGEWIDTH = 0.25

PC_PAIRS = [
    ("PC1", "PC2"),
    ("PC1", "PC3"),
    ("PC2", "PC3"),
    ("PC3", "PC4"),
]

SPECIES_COLORS = {
    "G.max": "#f28e2b",
    "G.soja": "#2ca25f",
}

ECOTYPE_COLORS = {
    "Cultivar": "#f28e2b",
    "Landrace": "#4e79a7",
}

MATURITY_COLORS = {
    "I": "#9ecae1",
    "II": "#6baed6",
    "III": "#3182bd",
    "IV": "#756bb1",
    "V": "#54278f",
    "VI": "#9e9ac8",
    "VII": "#fdae6b",
    "VIII": "#fd8d3c",
    "IX": "#d62728",
    "X": "#a50f15",
}

CONFIG = {
    "Domestication": {
        "color_col": "Species",
        "palette": SPECIES_COLORS,
        "order": ["G.soja", "G.max"],
        "title": "Soybean PCA: Domestication",
    },
    "Improvement": {
        "color_col": "Ecotype",
        "palette": ECOTYPE_COLORS,
        "order": ["Cultivar", "Landrace"],
        "title": "Soybean PCA: Improvement",
    },
    "Adaptation": {
        "color_col": "Maturity_group",
        "palette": MATURITY_COLORS,
        "order": ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"],
        "title": "Soybean PCA: Adaptation",
    },
}

def load_eigenvec(path):
    df = pd.read_csv(path, sep=r"\s+", engine="python", header=None)
    ncols = df.shape[1]
    if ncols < 6:
        raise ValueError(f"{path}: expected at least 6 columns")
    df.columns = ["FID", "IID"] + [f"PC{i}" for i in range(1, ncols - 1)]
    return df

def load_eigenval(path):
    return pd.read_csv(path, header=None)[0].tolist()

def percent_var(vals):
    total = sum(vals)
    return [100 * v / total if total > 0 else 0 for v in vals]

def make_scatter(df, x, y, color_col, palette, order, title, out_png, out_pdf):
    plt.figure(figsize=(FIG_W, FIG_H))

    for grp in order:
        sub = df[df[color_col] == grp]
        if len(sub) == 0:
            continue
        plt.scatter(
            sub[x], sub[y],
            s=POINT_SIZE,
            alpha=ALPHA,
            c=palette.get(grp, "#999999"),
            edgecolors="black",
            linewidths=EDGEWIDTH,
            label=f"{grp} (n={len(sub)})"
        )

    plt.xlabel(df.attrs.get(f"{x}_label", x))
    plt.ylabel(df.attrs.get(f"{y}_label", y))
    plt.title(title, fontsize=10)
    plt.legend(frameon=False, fontsize=7, loc="best")
    plt.tight_layout()
    plt.savefig(out_png, dpi=DPI)
    plt.savefig(out_pdf)
    plt.close()

meta = pd.read_csv(META_FILE)
meta.columns = meta.columns.str.strip()
meta = meta.drop_duplicates(subset=["Sample"]).copy()

os.makedirs(OUT_ROOT, exist_ok=True)

for name, cfg in CONFIG.items():
    eigenvec_file = os.path.join(PCA_DIR, f"{name}.eigenvec")
    eigenval_file = os.path.join(PCA_DIR, f"{name}.eigenval")

    pca = load_eigenvec(eigenvec_file)
    evals = load_eigenval(eigenval_file)
    pvar = percent_var(evals)

    merged = pca.merge(meta, left_on="IID", right_on="Sample", how="left")

    for i in range(4):
        pc = f"PC{i+1}"
        merged.attrs[f"{pc}_label"] = f"{pc} ({pvar[i]:.2f}%)"

    color_col = cfg["color_col"]
    palette = cfg["palette"]
    order = cfg["order"]

    sub = merged.dropna(subset=[color_col]).copy()

    outdir = os.path.join(OUT_ROOT, name)
    os.makedirs(outdir, exist_ok=True)

    sub.to_csv(os.path.join(outdir, f"{name}_PCA_table.tsv"), sep="\t", index=False)

    for x, y in PC_PAIRS:
        out_png = os.path.join(outdir, f"{name}_{x}_vs_{y}.png")
        out_pdf = os.path.join(outdir, f"{name}_{x}_vs_{y}.pdf")

        make_scatter(
            df=sub,
            x=x,
            y=y,
            color_col=color_col,
            palette=palette,
            order=order,
            title=f"{cfg['title']} ({x} vs {y})",
            out_png=out_png,
            out_pdf=out_pdf
        )

    print(f"\n{name}")
    print(sub[color_col].value_counts(dropna=False))
    print(f"Saved to: {outdir}")

print("\nFinished all separate PCA plots.")




