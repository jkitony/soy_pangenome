#!/bin/bash
set -euo pipefail

VCF="soy.snp.bi.filt.vcf.gz"
OUTDIR="Separate_PCA"
mkdir -p "${OUTDIR}"

run_pca () {
    NAME=$1
    KEEP=$2

    echo "Running ${NAME} ..."

    # Step 1: convert subset to PLINK
    plink --vcf "${VCF}" \
      --allow-extra-chr \
      --double-id \
      --keep "${KEEP}" \
      --make-bed \
      --out "${OUTDIR}/${NAME}"

    # Step 2: LD pruning
    plink --bfile "${OUTDIR}/${NAME}" \
      --indep-pairwise 50 5 0.2 \
      --out "${OUTDIR}/${NAME}"

    # Step 3: PCA on pruned SNPs
    plink --bfile "${OUTDIR}/${NAME}" \
      --extract "${OUTDIR}/${NAME}.prune.in" \
      --pca 4 \
      --out "${OUTDIR}/${NAME}"
}

run_pca "Domestication" "Domestication.keep"
run_pca "Improvement"   "Improvement.keep"
run_pca "Adaptation"    "Adaptation.keep"

echo "All PCA runs completed."

