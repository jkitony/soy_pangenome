    return x

def normalize_species(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    fixes = {
        "G.max": "G.max",
        "G max": "G.max",
        "Glycine max": "G.max",
        "max": "G.max",
        "G.soja": "G.soja",
        "G soja": "G.soja",
        "Glycine soja": "G.soja",
        "soja": "G.soja",
    }
    return fixes.get(x, x)

def normalize_ecotype(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    fixes = {
        "cultivar": "Cultivar",
        "Cultivar": "Cultivar",
        "landrace": "Landrace",
        "Landrace": "Landrace",
        "wild": "Wild_type",
        "wild type": "Wild_type",
        "Wild type": "Wild_type",
        "Wild_type": "Wild_type",
        "breeder line": "Breeder_line",
        "Breeder line": "Breeder_line",
        "Breeder_line": "Breeder_line",
    }
    return fixes.get(x, x)

def normalize_maturity(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    x = re.sub(r"\s+", "", x)

    fixes = {
        "0": "Wild",
        "O": "Wild",
    }
    if x in fixes:
        return fixes[x]

    valid = {"Wild", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"}
    return x if x in valid else pd.NA

def write_keep(df, outfile):
    with open(outfile, "w") as f:
        for s in df["Sample"].dropna().astype(str).unique():
            f.write(f"{s}\t{s}\n")

try:
    meta = pd.read_csv(meta_file, encoding="utf-8")
except UnicodeDecodeError:
    meta = pd.read_csv(meta_file, encoding="latin1", low_memory=False)

meta.columns = meta.columns.str.strip()

required = ["Sample", "Species", "Ecotype", "Maturity_group"]
for col in required:
    if col not in meta.columns:
        raise ValueError(f"Missing required column: {col}")

for col in required:
    meta[col] = meta[col].apply(clean_text)

meta["Species"] = meta["Species"].apply(normalize_species)
meta["Ecotype"] = meta["Ecotype"].apply(normalize_ecotype)
meta["Maturity_group"] = meta["Maturity_group"].apply(normalize_maturity)

meta = meta.drop_duplicates(subset=["Sample"]).copy()

# 1. Domestication: G.max vs G.soja
dom = meta[meta["Species"].isin(["G.max", "G.soja"])].copy()
write_keep(dom, "Domestication.keep")

# 2. Improvement: Cultivar vs Landrace
# usually best to keep only samples with those labels
imp = meta[meta["Ecotype"].isin(["Cultivar", "Landrace"])].copy()
write_keep(imp, "Improvement.keep")

# 3. Adaptation: only G.max with maturity group
# this avoids the wild/domestication split masking maturity structure
adp = meta[
    (meta["Species"] == "G.max") &
    (meta["Maturity_group"].notna()) &
    (meta["Maturity_group"] != "Wild")
].copy()
write_keep(adp, "Adaptation.keep")

# Also save cleaned metadata
meta.to_csv("Meta.cleaned.csv", index=False)

print("Done.")
print(f"Domestication samples: {len(dom)}")
print(dom["Species"].value_counts(dropna=False))
print()
print(f"Improvement samples: {len(imp)}")
print(imp["Ecotype"].value_counts(dropna=False))
print()
print(f"Adaptation samples: {len(adp)}")
print(adp["Maturity_group"].value_counts(dropna=False).sort_index())

