#!/usr/bin/env python3

import os
import re
import pandas as pd
import matplotlib.pyplot as plt

# =========================================================
# INPUT FILES
# =========================================================
meta_file = "Meta.csv"
eigenvec_file = "soy.snp.bi.filt.eigenvec"
eigenval_file = "soy.snp.bi.filt.eigenval"
out_root = "PCA_by_biology"

# =========================================================
# SETTINGS
# =========================================================
FIG_W = 4
FIG_H = 4
DPI = 600
POINT_SIZE = 18
ALPHA = 0.9
EDGEWIDTH = 0.25

# Pairwise PC plots to save
PC_PAIRS = [
    ("PC1", "PC2"),
    ("PC1", "PC3"),
    ("PC2", "PC3"),
    ("PC3", "PC4"),
]

# Colors
SPECIES_COLORS = {
    "G.max": "#f28e2b",
    "G.soja": "#2ca25f",
}

ECOTYPE_COLORS = {
    "Cultivar": "#f28e2b",
    "Landrace": "#4e79a7",
    "Wild_type": "#2ca25f",
    "Breeder_line": "#8e63ce",
}

MATURITY_COLORS = {
    "Wild": "#2ca25f",
    "I": "#9ecae1",
    "II": "#6baed6",
    "III": "#3182bd",
    "IV": "#756bb1",
    "V": "#54278f",
    "VI": "#9e9ac8",
    "VII": "#fdae6b",
    "VIII": "#fd8d3c",
    "IX": "#d62728",
    "X": "#a50f15",
}

# =========================================================
# HELPERS
# =========================================================
def clean_text(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    if x in {"", "NA", "N/A", "nan", "None", "<NA>", "unknown", "Unknown"}:
        return pd.NA
    return x

def normalize_species(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    fixes = {
        "Glycine max": "G.max",
        "G max": "G.max",
        "G.max": "G.max",
        "max": "G.max",
        "Glycine soja": "G.soja",
        "G soja": "G.soja",
        "G.soja": "G.soja",
        "soja": "G.soja",
    }
    return fixes.get(x, x)

def normalize_ecotype(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    fixes = {
        "cultivar": "Cultivar",
        "landrace": "Landrace",
        "wild": "Wild_type",
        "wild type": "Wild_type",
        "Wild type": "Wild_type",
        "wild_type": "Wild_type",
        "breeder line": "Breeder_line",
        "Breeder line": "Breeder_line",
        "breeder_line": "Breeder_line",
    }
    return fixes.get(x, x)

def normalize_maturity(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()

    # strip spaces
    x = re.sub(r"\s+", "", x)

    fixes = {
        "0": "Wild",
        "O": "Wild",
    }
    if x in fixes:
        return fixes[x]

    valid = {"I","II","III","IV","V","VI","VII","VIII","IX","X","Wild"}
    return x if x in valid else pd.NA

def load_eigenvec(path):
    df = pd.read_csv(path, sep=r"\s+", engine="python", header=None)
    ncols = df.shape[1]

    if ncols < 6:
        raise ValueError("Expected at least 6 columns in eigenvec (FID IID PC1 PC2 PC3 PC4).")

    colnames = ["FID", "IID"] + [f"PC{i}" for i in range(1, ncols - 1)]
    df.columns = colnames
    return df

def load_eigenval(path, n=4):
    vals = pd.read_csv(path, header=None)[0].tolist()
    return vals[:n]

def percent_var(evals):
    total = sum(evals)
    if total == 0:
        return [None] * len(evals)
    return [100 * x / total for x in evals]

def make_scatter(df, x, y, color_col, palette, title, out_png, out_pdf, order=None):
    plt.figure(figsize=(FIG_W, FIG_H))

    groups = order if order is not None else sorted(df[color_col].dropna().unique())

    for grp in groups:
        sub = df[df[color_col] == grp]
        if len(sub) == 0:
            continue
        plt.scatter(
            sub[x], sub[y],
            s=POINT_SIZE,
            alpha=ALPHA,
            c=palette.get(grp, "#999999"),
            edgecolors="black",
            linewidths=EDGEWIDTH,
            label=f"{grp} (n={len(sub)})"
        )

    plt.xlabel(df.attrs.get(f"{x}_label", x))
    plt.ylabel(df.attrs.get(f"{y}_label", y))
    plt.title(title, fontsize=10)
    plt.legend(frameon=False, fontsize=7, loc="best")
    plt.tight_layout()
    plt.savefig(out_png, dpi=DPI)
    plt.savefig(out_pdf)
    plt.close()

# =========================================================
# READ METADATA
# =========================================================
try:
    meta = pd.read_csv(meta_file, encoding="utf-8")
except UnicodeDecodeError:
    meta = pd.read_csv(meta_file, encoding="latin1", low_memory=False)

meta.columns = meta.columns.str.strip()

required_cols = ["Sample", "Species", "Ecotype", "Maturity_group"]
for col in required_cols:
    if col not in meta.columns:
        raise ValueError(f"Missing required metadata column: {col}")

for col in required_cols:
    meta[col] = meta[col].apply(clean_text)

meta["Species"] = meta["Species"].apply(normalize_species)
meta["Ecotype"] = meta["Ecotype"].apply(normalize_ecotype)
meta["Maturity_group"] = meta["Maturity_group"].apply(normalize_maturity)

# keep one row per sample
meta = meta.drop_duplicates(subset=["Sample"]).copy()

# =========================================================
# READ PCA
# =========================================================
pca = load_eigenvec(eigenvec_file)
evals = load_eigenval(eigenval_file, n=4)
pvar = percent_var(evals)

# plink with --double-id often makes IID = sample name
merged = pca.merge(meta, left_on="IID", right_on="Sample", how="left")

# annotate axis labels
for i in range(4):
    pc = f"PC{i+1}"
    if i < len(pvar) and pvar[i] is not None:
        merged.attrs[f"{pc}_label"] = f"{pc} ({pvar[i]:.2f}%)"
    else:
        merged.attrs[f"{pc}_label"] = pc

# =========================================================
# OUTPUT DIRS
# =========================================================
comparisons = {
    "Domestication": {
        "column": "Species",
        "palette": SPECIES_COLORS,
        "order": ["G.soja", "G.max"],
        "title": "Soybean PCA: Domestication",
    },
    "Improvement": {
        "column": "Ecotype",
        "palette": ECOTYPE_COLORS,
        "order": ["Cultivar", "Landrace", "Wild_type", "Breeder_line"],
        "title": "Soybean PCA: Improvement",
    },
    "Adaptation": {
        "column": "Maturity_group",
        "palette": MATURITY_COLORS,
        "order": ["Wild", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"],
        "title": "Soybean PCA: Adaptation",
    },
}

os.makedirs(out_root, exist_ok=True)

# =========================================================
# SAVE SAMPLE MATCH REPORT
# =========================================================
match_report = merged[["FID", "IID", "Sample", "Species", "Ecotype", "Maturity_group"]].copy()
match_report["Matched_meta"] = match_report["Sample"].notna()
match_report.to_csv(os.path.join(out_root, "PCA_metadata_match_report.tsv"), sep="\t", index=False)

# =========================================================
# PLOT
# =========================================================
for comp_name, cfg in comparisons.items():
    comp_dir = os.path.join(out_root, comp_name)
    os.makedirs(comp_dir, exist_ok=True)

    color_col = cfg["column"]
    palette = cfg["palette"]
    order = cfg["order"]

    sub = merged.dropna(subset=[color_col]).copy()
    sub.to_csv(os.path.join(comp_dir, f"{comp_name}_PCA_table.tsv"), sep="\t", index=False)

    for x, y in PC_PAIRS:
        out_png = os.path.join(comp_dir, f"{comp_name}_{x}_vs_{y}.png")
        out_pdf = os.path.join(comp_dir, f"{comp_name}_{x}_vs_{y}.pdf")

        make_scatter(
            df=sub,
            x=x,
            y=y,
            color_col=color_col,
            palette=palette,
            title=f"{cfg['title']} ({x} vs {y})",
            out_png=out_png,
            out_pdf=out_pdf,
            order=order
        )

# =========================================================
# SUMMARY
# =========================================================
print("Finished PCA plotting.")
print(f"Output root: {out_root}")
print(f"Total PCA samples: {len(pca)}")
print(f"Matched to metadata: {merged['Sample'].notna().sum()}")
print(f"Unmatched PCA samples: {merged['Sample'].isna().sum()}")

for comp_name, cfg in comparisons.items():
    color_col = cfg["column"]
    sub = merged.dropna(subset=[color_col]).copy()
    print(f"\n[{comp_name}] {color_col}")
    print(sub[color_col].value_counts(dropna=False))

