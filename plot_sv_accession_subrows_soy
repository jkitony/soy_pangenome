#!/usr/bin/env python3

import argparse
import math
import os
import pandas as pd
import pysam
import matplotlib.pyplot as plt
from matplotlib.lines import Line2D

CHR_ORDER = [f"Chr{i:02d}" for i in range(1, 21)]

COLORS = {
    "DEL": "red",
    "INS": "orange",
    "DUP": "green",
    "INV": "blue"
}


def read_sample_order(vcf_list_file):
    samples = []
    with open(vcf_list_file) as f:
        for line in f:
            path = line.strip()
            if not path:
                continue
            base = os.path.basename(path)
            sample = base.replace(".sv.ge50.sorted.vcf.gz", "")
            sample = sample.replace(".sv.ge50.sorted.vcf", "")
            sample = sample.replace(".vcf.gz", "")
            sample = sample.replace(".vcf", "")
            samples.append(sample)
    return samples


def get_svlen(rec):
    pos = rec.pos
    end = rec.stop if rec.stop else pos
    svlen = rec.info.get("SVLEN", end - pos + 1)
    if isinstance(svlen, tuple):
        svlen = svlen[0]
    try:
        return abs(int(svlen))
    except Exception:
        return abs(int(end - pos + 1))


def make_offsets(types):
    n = len(types)
    if n == 1:
        return {types[0]: 0.0}

    span = 0.54
    step = span / (n - 1)
    start = -span / 2
    return {svt: start + i * step for i, svt in enumerate(types)}


def parse_sv_rows(vcf, samples, svtypes, minlens, chrom_filter=None):
    rows = []
    n_samples = len(samples)

    for rec in vcf:
        svtype = rec.info.get("SVTYPE", "NA")
        if svtype not in svtypes:
            continue

        chrom = rec.contig
        if chrom not in CHR_ORDER:
            continue
        if chrom_filter is not None and chrom != chrom_filter:
            continue

        pos = rec.pos
        end = rec.stop if rec.stop else pos
        svlen = get_svlen(rec)

        if svlen < minlens.get(svtype, 0):
            continue

        supp_vec = rec.info.get("SUPP_VEC", "")
        if isinstance(supp_vec, tuple):
            supp_vec = supp_vec[0]
        supp_vec = str(supp_vec)

        if len(supp_vec) != n_samples:
            continue

        for i, bit in enumerate(supp_vec):
            if bit == "1":
                rows.append({
                    "CHROM": chrom,
                    "POS": pos,
                    "END": end,
                    "SVLEN": svlen,
                    "SVTYPE": svtype,
                    "Sample": samples[i]
                })

    return pd.DataFrame(rows)


def build_legend_elements(types):
    return [
        Line2D([0], [0], color=COLORS[t], lw=2, label=t)
        for t in types
    ]


def choose_label_step(n_samples):
    if n_samples <= 50:
        return 1
    elif n_samples <= 100:
        return 2
    elif n_samples <= 160:
        return 4
    elif n_samples <= 250:
        return 5
    else:
        return 10


def plot_single_chrom(df, sample_order, offsets, types, chrom, outprefix, figwidth, figheight):
    sample_to_y = {s: i for i, s in enumerate(sample_order, start=1)}
    n_samples = len(sample_order)

    fig, axes = plt.subplots(
        2, 1,
        figsize=(figwidth, figheight),
        gridspec_kw={"height_ratios": [1.0, 0.10]}
    )

    ax = axes[0]
    legend_ax = axes[1]

    for svtype in types:
        sub = df[(df["CHROM"] == chrom) & (df["SVTYPE"] == svtype)]
        for _, r in sub.iterrows():
            y = sample_to_y[r["Sample"]] + offsets[svtype]
            ax.plot(
                [r["POS"], r["END"]],
                [y, y],
                color=COLORS.get(svtype, "black"),
                linewidth=1.2,
                alpha=0.85,
                solid_capstyle="butt",
                rasterized=True
            )

    ax.set_title(chrom, fontsize=9, pad=3)

    label_step = choose_label_step(n_samples)
    yticks_all = [sample_to_y[s] for s in sample_order]
    ylabels_all = sample_order
    yticks = yticks_all[::label_step]
    ylabels = ylabels_all[::label_step]

    ax.set_yticks(yticks)
    ax.set_yticklabels(ylabels, fontsize=4)
    ax.set_ylabel("Accession", fontsize=6, labelpad=2)

    ax.tick_params(axis="x", labelsize=6, length=2, pad=1)
    ax.tick_params(axis="y", labelsize=4, length=0, pad=1)

    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    ax.set_ylim(n_samples + 0.8, 0.2)

    xticks = ax.get_xticks()
    ax.set_xticks(xticks)
    ax.set_xticklabels([f"{x/1e6:.0f}" if x > 0 else "0" for x in xticks], fontsize=6)
    ax.set_xlabel("Mb", fontsize=6, labelpad=1)

    legend_ax.axis("off")
    legend_ax.legend(
        handles=build_legend_elements(types),
        loc="center",
        frameon=False,
        ncol=len(types),
        fontsize=6,
        handlelength=1.6,
        columnspacing=1.0
    )

    fig.subplots_adjust(
        left=0.24,
        right=0.98,
        top=0.94,
        bottom=0.08,
        hspace=0.05
    )

    fig.savefig(outprefix + ".png", dpi=600, bbox_inches="tight")
    fig.savefig(outprefix + ".pdf", bbox_inches="tight")

    print("[INFO] Wrote:")
    print(outprefix + ".png")
    print(outprefix + ".pdf")


def plot_all_chroms(df, sample_order, offsets, types, outprefix, figwidth=16, figheight=18, ncols=5):
    sample_to_y = {s: i for i, s in enumerate(sample_order, start=1)}
    n_samples = len(sample_order)

    nchrom = len(CHR_ORDER)
    nrows_panels = math.ceil(nchrom / ncols)
    nrows_total = nrows_panels + 1

    height_ratios = [1] * nrows_panels + [0.12]

    fig, axes = plt.subplots(
        nrows_total,
        ncols,
        figsize=(figwidth, figheight),
        sharey=True,
        gridspec_kw={"height_ratios": height_ratios}
    )

    if nrows_total == 1:
        axes = [axes]

    chrom_axes = axes[:nrows_panels].flatten()

    for ax, chrom in zip(chrom_axes, CHR_ORDER):
        sub = df[df["CHROM"] == chrom]

        for svtype in types:
            sub2 = sub[sub["SVTYPE"] == svtype]
            for _, r in sub2.iterrows():
                y = sample_to_y[r["Sample"]] + offsets[svtype]
                ax.plot(
                    [r["POS"], r["END"]],
                    [y, y],
                    color=COLORS.get(svtype, "black"),
                    linewidth=0.8,
                    alpha=0.8,
                    solid_capstyle="butt",
                    rasterized=True
                )

        ax.set_title(chrom, fontsize=7, pad=2)
        ax.tick_params(axis="x", labelsize=5, length=2, pad=1)
        ax.tick_params(axis="y", labelsize=4, length=0, pad=1)

        ax.spines["top"].set_visible(False)
        ax.spines["right"].set_visible(False)

        ax.set_ylim(n_samples + 0.8, 0.2)

        xticks = ax.get_xticks()
        ax.set_xticks(xticks)
        ax.set_xticklabels([f"{x/1e6:.0f}" if x > 0 else "0" for x in xticks], fontsize=5)
        ax.set_xlabel("Mb", fontsize=5, labelpad=1)

    # hide unused chromosome axes if any
    for j in range(len(CHR_ORDER), len(chrom_axes)):
        chrom_axes[j].axis("off")

    label_step = choose_label_step(n_samples)

    for i, ax in enumerate(chrom_axes[:len(CHR_ORDER)]):
        if i % ncols == 0:
            yticks_all = [sample_to_y[s] for s in sample_order]
            ylabels_all = sample_order
            yticks = yticks_all[::label_step]
            ylabels = ylabels_all[::label_step]
            ax.set_yticks(yticks)
            ax.set_yticklabels(ylabels, fontsize=4)
            ax.set_ylabel("Accession", fontsize=6, labelpad=2)
        else:
            ax.tick_params(labelleft=False)

    # legend row
    legend_axes = axes[nrows_panels]
    if not isinstance(legend_axes, (list, tuple)):
        try:
            legend_axes = legend_axes.flatten()
        except Exception:
            legend_axes = [legend_axes]

    for ax in legend_axes:
        ax.axis("off")

    center_idx = len(legend_axes) // 2
    legend_axes[center_idx].legend(
        handles=build_legend_elements(types),
        loc="center",
        frameon=False,
        ncol=len(types),
        fontsize=7,
        handlelength=1.6,
        columnspacing=1.0
    )

    fig.subplots_adjust(
        left=0.16,
        right=0.98,
        top=0.97,
        bottom=0.05,
        wspace=0.16,
        hspace=0.22
    )

    fig.savefig(outprefix + ".png", dpi=600, bbox_inches="tight")
    fig.savefig(outprefix + ".pdf", bbox_inches="tight")

    print("[INFO] Wrote:")
    print(outprefix + ".png")
    print(outprefix + ".pdf")


def main():
    parser = argparse.ArgumentParser(
        description="Accession-level SV map with subrows within each accession"
    )
    parser.add_argument("--vcf", required=True)
    parser.add_argument("--vcf_list", required=True)
    parser.add_argument("--outprefix", required=True)
    parser.add_argument("--types", nargs="+", default=["INV", "DUP", "DEL", "INS"])

    parser.add_argument("--inv_minlen", type=int, default=0)
    parser.add_argument("--dup_minlen", type=int, default=0)
    parser.add_argument("--del_minlen", type=int, default=0)
    parser.add_argument("--ins_minlen", type=int, default=0)

    parser.add_argument("--chrom", default=None, help="Optional single chromosome, e.g. Chr04")
    parser.add_argument("--figwidth", type=float, default=16)
    parser.add_argument("--figheight", type=float, default=18)
    parser.add_argument("--ncols", type=int, default=5, help="Number of columns in whole-genome plot")
    args = parser.parse_args()

    samples = read_sample_order(args.vcf_list)

    minlens = {
        "INV": args.inv_minlen,
        "DUP": args.dup_minlen,
        "DEL": args.del_minlen,
        "INS": args.ins_minlen
    }

    vcf = pysam.VariantFile(args.vcf)
    df = parse_sv_rows(vcf, samples, args.types, minlens, chrom_filter=args.chrom)

    if df.empty:
        print("[WARN] No SVs found with these filters.")
        return

    sample_counts = df["Sample"].value_counts()
    sample_order = sample_counts.sort_values(ascending=False).index.tolist()
    offsets = make_offsets(args.types)

    if args.chrom is not None:
        plot_single_chrom(
            df=df,
            sample_order=sample_order,
            offsets=offsets,
            types=args.types,
            chrom=args.chrom,
            outprefix=args.outprefix,
            figwidth=args.figwidth,
            figheight=args.figheight
        )
    else:
        plot_all_chroms(
            df=df,
            sample_order=sample_order,
            offsets=offsets,
            types=args.types,
            outprefix=args.outprefix,
            figwidth=args.figwidth,
            figheight=args.figheight,
            ncols=args.ncols
        )


if __name__ == "__main__":
    main()
