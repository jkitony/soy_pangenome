#!/usr/bin/env python3

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import os
import re

OUTDIR = "plots"
TABLEDIR = "tables"

os.makedirs(OUTDIR, exist_ok=True)
os.makedirs(TABLEDIR, exist_ok=True)

FILES = {
    "SNP_dom": "/data1/jkitony/soybean/SNPs_selection_scan/XPCLRS/annotation/domestication_GO_enrichment_real_background.tsv",
    "SNP_imp": "/data1/jkitony/soybean/SNPs_selection_scan/XPCLRS/annotation/improvement_GO_enrichment_real_background.tsv",
    "SV_dom": "/data1/jkitony/soybean/SVs_selection_scan/XPCLRS_SV/annotation/domestication_sv_GO_enrichment_real_background.tsv",
    "SV_imp": "/data1/jkitony/soybean/SVs_selection_scan/XPCLRS_SV/annotation/improvement_sv_GO_enrichment_real_background.tsv",
}

# Broad or uninformative terms to remove by exact match
REMOVE_EXACT = [
    "metabolic process",
    "cellular process",
    "biological_process",
]

# Animal/medical/cross-kingdom artifact terms to remove by keyword
BLACKLIST_KEYWORDS = [
    "angiogenesis",
    "blood",
    "blood pressure",
    "blood vessel",
    "arterial",
    "endothelial",
    "cardiac",
    "heart",
    "muscle",
    "neuron",
    "neuronal",
    "synapse",
    "axon",
    "dendrite",
    "brain",
    "learning",
    "memory",
    "locomotion",
    "behavior",
    "placenta",
    "embryonic placenta",
    "mammary",
    "immune system process",
    "adaptive immune",
    "antibody",
    "lymphocyte",
    "leukocyte",
    "macrophage",
    "T cell",
    "B cell",
]

# Fungal/cell-fusion artifacts that are usually not useful for soybean interpretation
BLACKLIST_KEYWORDS += [
    "fungal-type",
    "mating projection",
    "conjugation with cellular fusion",
    "septum digestion",
    "primary cell septum",
    "division septum",
]

blacklist_pattern = re.compile(
    "|".join([re.escape(x) for x in BLACKLIST_KEYWORDS]),
    flags=re.IGNORECASE
)

dfs = []

for label, path in FILES.items():

    df = pd.read_csv(path, sep="\t")

    df = df[df["GO_category"] == "BP"].copy()

    df["minus_log10_FDR"] = -np.log10(
        df["FDR"].replace(0, np.nextafter(0, 1))
    )

    df["Dataset"] = label

    dfs.append(df)

all_df = pd.concat(dfs, ignore_index=True)

# keep informative terms
all_df = all_df[
    (all_df["FDR"] < 0.1) &
    (all_df["GO_term"].notna()) &
    (all_df["GO_term"] != "NA")
].copy()

# remove broad exact terms
all_df = all_df[
    ~all_df["GO_term"].isin(REMOVE_EXACT)
].copy()

# remove blacklisted artifact terms
all_df["Blacklisted"] = all_df["GO_term"].astype(str).apply(
    lambda x: bool(blacklist_pattern.search(x))
)

removed = all_df[all_df["Blacklisted"]].copy()

removed.to_csv(
    f"{TABLEDIR}/GO_terms_removed_blacklist.tsv",
    sep="\t",
    index=False
)

all_df = all_df[~all_df["Blacklisted"]].copy()

# save curated long-format table
all_df.to_csv(
    f"{TABLEDIR}/GO_comparison_curated_long.tsv",
    sep="\t",
    index=False
)

# select strongest terms overall
top_terms = (
    all_df.groupby("GO_term")["minus_log10_FDR"]
    .max()
    .sort_values(ascending=False)
    .head(30)
    .index
)

plot_df = all_df[
    all_df["GO_term"].isin(top_terms)
].copy()

heat = plot_df.pivot_table(
    index="GO_term",
    columns="Dataset",
    values="minus_log10_FDR",
    fill_value=0
)

# enforce column order
heat = heat.reindex(
    columns=["SNP_dom", "SNP_imp", "SV_dom", "SV_imp"]
)

# order terms by strongest signal
heat = heat.loc[
    heat.max(axis=1).sort_values().index
]

heat.to_csv(
    f"{TABLEDIR}/GO_comparison_heatmap.tsv",
    sep="\t"
)

# plot
fig, ax = plt.subplots(figsize=(9, 11))

im = ax.imshow(
    heat.values,
    aspect="auto"
)

ax.set_xticks(range(len(heat.columns)))
ax.set_xticklabels(heat.columns)

ax.set_yticks(range(len(heat.index)))
ax.set_yticklabels(heat.index, fontsize=8)

cbar = plt.colorbar(im)
cbar.set_label("-log10(FDR)")

ax.set_title(
    "Functional comparison of SNP- and SV-associated sweeps"
)

plt.tight_layout()

plt.savefig(
    f"{OUTDIR}/GO_comparison_heatmap.png",
    dpi=300
)

plt.savefig(
    f"{OUTDIR}/GO_comparison_heatmap.pdf"
)

plt.close()

print("\nSaved:")
print(f"{OUTDIR}/GO_comparison_heatmap.png")
print(f"{TABLEDIR}/GO_comparison_heatmap.tsv")
print(f"{TABLEDIR}/GO_comparison_curated_long.tsv")
print(f"{TABLEDIR}/GO_terms_removed_blacklist.tsv")

print("\nRemoved blacklisted terms:")
if len(removed) == 0:
    print("None")
else:
    print(
        removed[["Dataset", "GO_term", "GO", "FDR"]]
        .drop_duplicates()
        .to_string(index=False)
    )

print("\nFinal heatmap terms:")
print(heat.index.to_series().to_string(index=False))
PY
