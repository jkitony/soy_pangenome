# =========================================================
# LOAD GEOJSON
# =========================================================
with open(geojson_file, "r", encoding="utf-8") as f:
    geo = json.load(f)

def get_feature_name(feature):
    props = feature.get("properties", {})
    for key in ["name", "ADMIN", "admin", "NAME", "country", "COUNTRY"]:
        if key in props and props[key]:
            return str(props[key]).strip()
    return None

# =========================================================
# COUNTRY CENTROIDS
# =========================================================
country_centroids = {}

for feature in geo["features"]:
    name = get_feature_name(feature)
    geom = feature.get("geometry")

    if not name or geom is None:
        continue

    coords_list = []

    if geom["type"] == "Polygon":
        for ring in geom["coordinates"]:
            coords_list.extend(ring)

    elif geom["type"] == "MultiPolygon":
        for poly in geom["coordinates"]:
            for ring in poly:
                coords_list.extend(ring)

    if coords_list:
        xs, ys = zip(*coords_list)
        country_centroids[name] = (sum(ys) / len(ys), sum(xs) / len(xs))

# =========================================================
# ASSIGN COORDINATES
# =========================================================
def assign_coords(row):
    country = row["Country"]
    location = row["Location"]

    if pd.notna(location):
        key = (country, location)
        if key in location_coords:
            lat, lon = location_coords[key]
            return pd.Series([f"{location}, {country}", lat, lon, "location"])

    if country in country_centroids:
        lat, lon = country_centroids[country]
        return pd.Series([country, lat, lon, "country_centroid"])

    return pd.Series([pd.NA, pd.NA, pd.NA, "unmapped"])

df[["Plot_place", "Latitude", "Longitude", "Coord_source"]] = df.apply(assign_coords, axis=1)

df_mapped = df.dropna(subset=["Latitude", "Longitude"]).copy()
df_mapped.to_csv(out_csv, index=False)

# =========================================================
# AGGREGATE
# =========================================================
agg = (
    df_mapped
    .groupby(["Plot_place", "Latitude", "Longitude", MATURITY_COL], dropna=False)
    .size()
    .reset_index(name="Count")
)

agg["Size"] = np.log1p(agg["Count"]) * POINT_SIZE_SCALE + MIN_SIZE

rng = np.random.default_rng(123)
agg["Plot_lon"] = agg["Longitude"] + rng.normal(0, 0.35, len(agg))
agg["Plot_lat"] = agg["Latitude"] + rng.normal(0, 0.25, len(agg))

# =========================================================
# PLOT
# =========================================================
fig, ax = plt.subplots(figsize=(FIG_WIDTH, FIG_HEIGHT))

for feature in geo["features"]:
    geom = feature.get("geometry")
    if geom is None:
        continue

    if geom["type"] == "Polygon":
        for ring in geom["coordinates"]:
            xs, ys = zip(*ring)
            ax.fill(
                xs, ys,
                facecolor=COUNTRY_FILL,
                edgecolor=COUNTRY_EDGE,
                linewidth=0.15,
                zorder=1
            )

    elif geom["type"] == "MultiPolygon":
        for poly in geom["coordinates"]:
            for ring in poly:
                xs, ys = zip(*ring)
                ax.fill(
                    xs, ys,
                    facecolor=COUNTRY_FILL,
                    edgecolor=COUNTRY_EDGE,
                    linewidth=0.15,
                    zorder=1
                )

for grp in valid_groups:
    sub = agg[agg[MATURITY_COL] == grp]
    if sub.empty:
        continue

    ax.scatter(
        sub["Plot_lon"],
        sub["Plot_lat"],
        s=sub["Size"],
        c=GROUP_COLORS[grp],
        alpha=POINT_ALPHA,
        edgecolors="black",
        linewidths=0.12,
        zorder=3
    )

legend_handles = [
    Line2D(
        [0], [0],
        marker="o",
        color="w",
        label=grp.replace("MG_", ""),
        markerfacecolor=GROUP_COLORS[grp],
        markeredgecolor="black",
        markeredgewidth=0.2,
        markersize=2.8
    )
    for grp in valid_groups
]

ax.legend(
    handles=legend_handles,
    loc="lower left",
    bbox_to_anchor=(-0.12, 0.01),
    fontsize=LEGEND_SIZE,
    frameon=False,
    handlelength=0.7,
    handletextpad=0.25,
    labelspacing=0.15,
    borderpad=0.1,
    ncol=3
)

ax.set_xlim(MAP_EXTENT[0], MAP_EXTENT[1])
ax.set_ylim(MAP_EXTENT[2], MAP_EXTENT[3])
ax.set_aspect("auto")
ax.set_xticks([])
ax.set_yticks([])

for spine in ax.spines.values():
    spine.set_visible(False)

ax.set_title("Maturity group distribution", fontsize=TITLE_SIZE, pad=1)

fig.subplots_adjust(left=0.005, right=0.995, top=0.90, bottom=0.02)

plt.savefig(out_png, dpi=PNG_DPI, bbox_inches="tight", pad_inches=0.003)
