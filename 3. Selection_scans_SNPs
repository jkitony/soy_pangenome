#!/usr/bin/env python3

import pandas as pd

META = "Meta.csv"
VCF_SAMPLES = "vcf_samples.txt"

GROUPS = ["Wild_type", "Landrace", "Cultivar"]

def clean(x):
    if pd.isna(x):
        return pd.NA
    x = str(x).strip()
    if x in {"", "NA", "N/A", "nan", "None", "<NA>"}:
        return pd.NA
    return x

def norm_ecotype(x):
    if pd.isna(x):
        return pd.NA

    x0 = str(x).strip()
    key = x0.lower().replace(" ", "_").replace("-", "_")

    fixes = {
        "wild": "Wild_type",
        "wild_type": "Wild_type",
        "g_soja": "Wild_type",
        "g._soja": "Wild_type",
        "glycine_soja": "Wild_type",
        "soja": "Wild_type",

        "landrace": "Landrace",
        "landraces": "Landrace",

        "cultivar": "Cultivar",
        "cultivars": "Cultivar",
        "improved": "Cultivar",
        "improved_cultivar": "Cultivar",
        "improved_cultivars": "Cultivar",
    }

    return fixes.get(key, x0)

try:
    meta = pd.read_csv(META, encoding="utf-8")
except UnicodeDecodeError:
    meta = pd.read_csv(META, encoding="latin1")

meta.columns = meta.columns.str.strip()

meta["Sample"] = meta["Sample"].apply(clean)
meta["Ecotype"] = meta["Ecotype"].apply(clean).apply(norm_ecotype)

meta = meta.dropna(subset=["Sample", "Ecotype"])
meta = meta.drop_duplicates(subset=["Sample"])

with open(VCF_SAMPLES) as f:
    vcf_samples = {line.strip() for line in f if line.strip()}

meta["in_vcf"] = meta["Sample"].isin(vcf_samples)

imp = meta[
    meta["in_vcf"] &
    meta["Ecotype"].isin(GROUPS)
].copy()

for group in GROUPS:
    samples = imp[imp["Ecotype"] == group]["Sample"].sort_values().tolist()

    outname = f"{group}.txt"
    with open(outname, "w") as f:
        for s in samples:
            f.write(f"{s}\n")

    print(f"{group} in VCF:", len(samples))

imp.to_csv("Selection_samples_in_vcf.tsv", sep="\t", index=False)

print("\nCounts from intersected metadata:")
print(imp["Ecotype"].value_counts())

print("\nSamples in metadata but not in VCF:")
print(meta.loc[~meta["in_vcf"], ["Sample", "Ecotype"]].head(20))

print("\nUnrecognized ecotype labels among samples in VCF:")
print(
    meta.loc[
        meta["in_vcf"] & ~meta["Ecotype"].isin(GROUPS),
        "Ecotype"
    ].value_counts()
)

