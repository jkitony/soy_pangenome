#!/usr/bin/env python3

import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import argparse
import os

def find_col(df, candidates):
    cols = {c.lower(): c for c in df.columns}
    for cand in candidates:
        if cand.lower() in cols:
            return cols[cand.lower()]
    raise ValueError(f"Could not find any of these columns: {candidates}\nAvailable: {list(df.columns)}")

def chr_sort_key(chrom):
    x = str(chrom).replace("Chr", "").replace("chr", "")
    try:
        return int(x)
    except ValueError:
        return x

def plot_xpclr(infile, outfile, title):
    df = pd.read_csv(infile, sep="\t")

    chr_col = find_col(df, ["chr", "chrom", "chromosome", "CHROM"])
    score_col = find_col(df, ["xpclr", "XPCLR", "score", "XP-CLR", "xpclr_score"])

    # position can vary by output version
    try:
        pos_col = find_col(df, ["pos", "position", "POS", "start", "START", "window_start"])
        df["POS"] = df[pos_col]
    except ValueError:
        start_col = find_col(df, ["start", "START", "window_start"])
        end_col = find_col(df, ["end", "END", "window_end"])
        df["POS"] = (df[start_col] + df[end_col]) / 2

    df = df[[chr_col, "POS", score_col]].copy()
    df.columns = ["CHR", "POS", "XPCLR"]

    df = df.dropna()
    df["CHR"] = df["CHR"].astype(str)
    df["XPCLR"] = pd.to_numeric(df["XPCLR"], errors="coerce")
    df["POS"] = pd.to_numeric(df["POS"], errors="coerce")
    df = df.dropna()

    df = df.sort_values(
        by=["CHR", "POS"],
        key=lambda s: s.map(chr_sort_key) if s.name == "CHR" else s
    )

    # cumulative position
    chr_offsets = {}
    offset = 0
    tick_pos = []
    tick_lab = []

    plot_dfs = []
    for chrom in sorted(df["CHR"].unique(), key=chr_sort_key):
        d = df[df["CHR"] == chrom].copy()
        d["BPcum"] = d["POS"] + offset
        chr_offsets[chrom] = offset
        tick_pos.append(d["BPcum"].median())
        tick_lab.append(chrom.replace("Chr", ""))
        offset = d["BPcum"].max()
        plot_dfs.append(d)

    plot_df = pd.concat(plot_dfs, ignore_index=True)

    threshold_95 = plot_df["XPCLR"].quantile(0.95)
    threshold_99 = plot_df["XPCLR"].quantile(0.99)

    plt.figure(figsize=(16, 5))

    for i, chrom in enumerate(sorted(plot_df["CHR"].unique(), key=chr_sort_key)):
        d = plot_df[plot_df["CHR"] == chrom]
        plt.scatter(
            d["BPcum"],
            d["XPCLR"],
            s=8,
            alpha=0.75
        )

    plt.axhline(threshold_95, linestyle="--", linewidth=1, label=f"Top 5% = {threshold_95:.3f}")
    plt.axhline(threshold_99, linestyle=":", linewidth=1, label=f"Top 1% = {threshold_99:.3f}")

    plt.xticks(tick_pos, tick_lab, fontsize=10)
    plt.xlabel("Chromosome")
    plt.ylabel("XP-CLR score")
    plt.title(title)
    plt.legend(frameon=False)
    plt.tight_layout()

    plt.savefig(outfile, dpi=300)
    plt.close()

    top_out = outfile.replace(".png", ".top5pct.tsv")
    plot_df[plot_df["XPCLR"] >= threshold_95].to_csv(top_out, sep="\t", index=False)

    print(f"Saved plot: {outfile}")
    print(f"Saved top 5% windows: {top_out}")
    print(f"Top 5% threshold: {threshold_95}")
    print(f"Top 1% threshold: {threshold_99}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--infile", required=True)
    parser.add_argument("--outfile", required=True)
    parser.add_argument("--title", required=True)
    args = parser.parse_args()

    plot_xpclr(args.infile, args.outfile, args.title)

