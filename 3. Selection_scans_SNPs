#!/usr/bin/env bash
set -euo pipefail

VCF="soy.snp.bi.filt.bcf"
GFF="Gmax_880_Wm82.a6.v1.gene.gff3"
SIF="xpclrs.sif"

WINDOW=100000
STEP=10000
MAXSNPS=250
MINSNPS=10
THREADS=45
MERGE_DIST=100000
TOP_Q=0.99

CHRS="Chr01 Chr02 Chr03 Chr04 Chr05 Chr06 Chr07 Chr08 Chr09 Chr10 Chr11 Chr12 Chr13 Chr14 Chr15 Chr16 Chr17 Chr18 Chr19 Chr20"

mkdir -p XPCLRS/domestication XPCLRS/improvement XPCLRS/combined XPCLRS/plots XPCLRS/annotation

echo "Running domestication scan: Wild_type vs Landrace"

for chr in ${CHRS}
do
    singularity exec ${SIF} xpclrs \
        --input ${VCF} \
        --out XPCLRS/domestication/${chr}.wild_vs_landrace.tsv \
        --samplesA Wild_type.txt \
        --samplesB Landrace.txt \
        --chr ${chr} \
        --size ${WINDOW} \
        --step ${STEP} \
        --maxsnps ${MAXSNPS} \
        --minsnps ${MINSNPS} \
        --threads ${THREADS} \
        --format tsv
done

echo "Running improvement scan: Landrace vs Cultivar"

for chr in ${CHRS}
do
    singularity exec ${SIF} xpclrs \
        --input ${VCF} \
        --out XPCLRS/improvement/${chr}.landrace_vs_cultivar.tsv \
        --samplesA Landrace.txt \
        --samplesB Cultivar.txt \
        --chr ${chr} \
        --size ${WINDOW} \
        --step ${STEP} \
        --maxsnps ${MAXSNPS} \
        --minsnps ${MINSNPS} \
        --threads ${THREADS} \
        --format tsv
done

echo "Combining chromosome outputs"

awk 'FNR==1 && NR!=1 {next} {print}' XPCLRS/domestication/*.xpclr \
    > XPCLRS/combined/domestication.full.tsv

awk 'FNR==1 && NR!=1 {next} {print}' XPCLRS/improvement/*.xpclr \
    > XPCLRS/combined/improvement.full.tsv

echo "Plotting Manhattan plots and extracting top 1% windows"

python plot_xpclr_manhattan.py \
    --infile XPCLRS/combined/domestication.full.tsv \
    --outfile_prefix XPCLRS/plots/domestication_XPCLR \
    --title "Domestication XP-CLR: Wild type vs Landrace" \
    --top_quantile ${TOP_Q}

python plot_xpclr_manhattan.py \
    --infile XPCLRS/combined/improvement.full.tsv \
    --outfile_prefix XPCLRS/plots/improvement_XPCLR \
    --title "Improvement XP-CLR: Landrace vs Cultivar" \
    --top_quantile ${TOP_Q}

echo "Preparing gene-only GFF"

awk '$3=="gene"' ${GFF} > XPCLRS/annotation/soybean.genes.gff3

echo "Preparing BED, merging sweeps, and extracting genes"

for scan in domestication improvement
do
    awk 'BEGIN{OFS="\t"} NR>1 {print $1,$2,$3,$11}' \
        XPCLRS/plots/${scan}_XPCLR.top1.full.tsv \
        > XPCLRS/annotation/${scan}.top1.bed

    bedtools sort -i XPCLRS/annotation/${scan}.top1.bed | \
    bedtools merge -d ${MERGE_DIST} -c 4 -o max \
        > XPCLRS/annotation/${scan}.top1.merged.bed

    awk 'BEGIN{OFS="\t"} {
        chr=$1
        gsub("Chr","Gm",chr)
        print chr,$2,$3,$4
    }' XPCLRS/annotation/${scan}.top1.merged.bed \
        > XPCLRS/annotation/${scan}.top1.merged.GFFchr.bed

    bedtools intersect \
        -a XPCLRS/annotation/soybean.genes.gff3 \
        -b XPCLRS/annotation/${scan}.top1.merged.GFFchr.bed \
        -wa -wb \
        > XPCLRS/annotation/${scan}.top1.selected_genes.tsv

    awk -F'\t' '
    {
        split($9,a,";")
        for(i in a){
            if(a[i] ~ /^ID=/){
                gsub("ID=","",a[i])
                print a[i]
            }
        }
    }' XPCLRS/annotation/${scan}.top1.selected_genes.tsv | \
    sort -u \
        > XPCLRS/annotation/${scan}.top1.gene_ids.txt
done

echo "Finding shared genes"

comm -12 \
    <(sort XPCLRS/annotation/domestication.top1.gene_ids.txt) \
    <(sort XPCLRS/annotation/improvement.top1.gene_ids.txt) \
    > XPCLRS/annotation/shared_domestication_improvement.top1.genes.txt

echo "Summary"

{
echo -e "Category\tCount"
echo -e "Domestication_top1_sweep_regions\t$(wc -l < XPCLRS/annotation/domestication.top1.merged.bed)"
echo -e "Improvement_top1_sweep_regions\t$(wc -l < XPCLRS/annotation/improvement.top1.merged.bed)"
echo -e "Domestication_top1_genes\t$(wc -l < XPCLRS/annotation/domestication.top1.gene_ids.txt)"
echo -e "Improvement_top1_genes\t$(wc -l < XPCLRS/annotation/improvement.top1.gene_ids.txt)"
echo -e "Shared_top1_genes\t$(wc -l < XPCLRS/annotation/shared_domestication_improvement.top1.genes.txt)"
} > XPCLRS/annotation/xpclr_top1_summary.tsv

cat XPCLRS/annotation/xpclr_top1_summary.tsv

echo "Done."


