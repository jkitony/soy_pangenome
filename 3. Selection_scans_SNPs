#!/usr/bin/env bash
set -euo pipefail

PROTEIN_FA="Gmax_880_Wm82.a6.v1.protein.fa"
ANN_DIR="XPCLRS/annotation"

for scan in domestication improvement
do
    echo "Processing ${scan}..."

    GENE_IDS="${ANN_DIR}/${scan}.top1.gene_ids.txt"
    LOCUS_IDS="${ANN_DIR}/${scan}.top1.locus_ids.txt"
    PATTERNS="${ANN_DIR}/${scan}.top1.seqkit_patterns.txt"
    ALL_PROTEINS="${ANN_DIR}/${scan}.top1.proteins.all_isoforms.fa"
    ONE_ISOFORM="${ANN_DIR}/${scan}.top1.proteins.one_isoform.fa"

    # 1. Convert Glyma.01G023300.Wm82.a6.v1 -> Glyma.01G023300
    sed 's/\.Wm82\.a6\.v1$//' "${GENE_IDS}" | sort -u > "${LOCUS_IDS}"

    # 2. Make seqkit regex patterns matching FASTA header field: locus=Glyma.01G023300
    awk '{print "locus="$1}' "${LOCUS_IDS}" > "${PATTERNS}"

    # 3. Extract all protein isoforms for selected loci
    seqkit grep -n -r -f "${PATTERNS}" "${PROTEIN_FA}" > "${ALL_PROTEINS}"

    # 4. Keep only one isoform per locus
    python - "${ALL_PROTEINS}" "${ONE_ISOFORM}" << 'PY'
import sys

infile = sys.argv[1]
outfile = sys.argv[2]

seen = set()
write = False

with open(infile) as fin, open(outfile, "w") as fout:
    for line in fin:
        if line.startswith(">"):
            header = line.strip()
            locus = None

            for field in header.split():
                if field.startswith("locus="):
                    locus = field.replace("locus=", "")
                    break

            if locus is None:
                write = False
                continue

            if locus in seen:
                write = False
            else:
                seen.add(locus)
                write = True
                fout.write(line)
        else:
            if write:
                fout.write(line)
PY

    echo "${scan} loci:"
    wc -l "${LOCUS_IDS}"

    echo "${scan} all isoform proteins:"
    grep -c "^>" "${ALL_PROTEINS}" || true

    echo "${scan} one isoform proteins:"
    grep -c "^>" "${ONE_ISOFORM}" || true

    echo
done

echo "Done."


