#!/usr/bin/env python3

import pandas as pd
import re
from pathlib import Path

files = {
    "Domestication": "06_eggnog/domestication/domestication_top1.emapper.annotations",
    "Improvement": "06_eggnog/improvement/improvement_top1.emapper.annotations",
}

outdir = Path("05_annotation")
outdir.mkdir(exist_ok=True)

def read_emapper(path):
    header = None
    with open(path) as f:
        for line in f:
            if line.startswith("#query"):
                header = line.strip().lstrip("#").split("\t")
                break

    df = pd.read_csv(path, sep="\t", comment="#", header=None)

    if header is not None and len(header) == df.shape[1]:
        df.columns = header

    return df

tables = []

for sweep_type, path in files.items():
    df = read_emapper(path)

    keep = {
        "query": "Protein_ID",
        "Description": "Description",
        "GOs": "GO_terms",
        "PFAMs": "Pfam_domain",
        "KEGG_Pathway": "KEGG_pathway",
        "KEGG_ko": "KEGG_ortholog",
        "COG_category": "COG_category",
        "Preferred_name": "Preferred_name",
    }

    available = [c for c in keep if c in df.columns]
    out = df[available].copy()
    out = out.rename(columns=keep)

    out["Gene_ID"] = out["Protein_ID"].astype(str).str.extract(
        r"(Gmax_Wm82a5\.Chr\d+\.g\d+)"
    )

    out["Sweep_type"] = sweep_type
    tables.append(out)

final = pd.concat(tables, ignore_index=True)

cols = [
    "Gene_ID",
    "Protein_ID",
    "Preferred_name",
    "Description",
    "GO_terms",
    "Pfam_domain",
    "KEGG_pathway",
    "KEGG_ortholog",
    "COG_category",
    "Sweep_type",
]

final = final[[c for c in cols if c in final.columns]]

outfile = outdir / "xpclr_top1_functional_annotation_table.tsv"
final.to_csv(outfile, sep="\t", index=False)

print(f"Saved: {outfile}")
print(final["Sweep_type"].value_counts())
EOF
