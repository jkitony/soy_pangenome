#!/usr/bin/env bash
set -euo pipefail

VCF="Merged_pangenie_multi-samples_Sep04_2025.vcf.gz"
OUTDIR="02_vcf"
THREADS=45

mkdir -p ${OUTDIR}

echo "Extracting biallelic SNPs..."

bcftools view \
  --threads ${THREADS} \
  -m2 -M2 -v snps \
  ${VCF} \
  -Oz \
  -o ${OUTDIR}/soy.snp.bi.raw.vcf.gz

tabix -p vcf ${OUTDIR}/soy.snp.bi.raw.vcf.gz

echo "Filling tags..."

bcftools +fill-tags \
  ${OUTDIR}/soy.snp.bi.raw.vcf.gz \
  -Oz \
  -o ${OUTDIR}/soy.snp.bi.tags.vcf.gz \
  -- -t MAF,F_MISSING,AC,AN

tabix -p vcf ${OUTDIR}/soy.snp.bi.tags.vcf.gz

echo "Filtering SNPs..."

bcftools view \
  --threads ${THREADS} \
  -i 'MAF>=0.05 && F_MISSING<=0.2' \
  ${OUTDIR}/soy.snp.bi.tags.vcf.gz \
  -Oz \
  -o ${OUTDIR}/soy.snp.bi.filt.vcf.gz

tabix -p vcf ${OUTDIR}/soy.snp.bi.filt.vcf.gz

bcftools query -l ${OUTDIR}/soy.snp.bi.filt.vcf.gz > ${OUTDIR}/vcf_samples.txt

echo "Final SNP count:"
bcftools view -H ${OUTDIR}/soy.snp.bi.filt.vcf.gz | wc -l

echo "Done."
EOF

