#!/usr/bin/env bash
set -euo pipefail

PROTEIN_FA="Wm82a5.protein.renamed.faa"
ANN_DIR="05_annotation"

for scan in domestication improvement; do
    echo "Processing ${scan}..."

    GENE_IDS="${ANN_DIR}/${scan}.top1.gene_ids.txt"
    PATTERNS="${ANN_DIR}/${scan}.top1.protein_patterns.txt"
    ALL_PROTEINS="${ANN_DIR}/${scan}.top1.proteins.all_isoforms.fa"
    ONE_ISOFORM="${ANN_DIR}/${scan}.top1.proteins.one_isoform.fa"

    awk '{print "gene="$1}' ${GENE_IDS} > ${PATTERNS}

    seqkit grep -n -r -f ${PATTERNS} ${PROTEIN_FA} > ${ALL_PROTEINS}

    python - ${ALL_PROTEINS} ${ONE_ISOFORM} << 'PY'
import sys
import re

infile = sys.argv[1]
outfile = sys.argv[2]

seen = set()
write = False

with open(infile) as fin, open(outfile, "w") as fout:
    for line in fin:
        if line.startswith(">"):
            header = line.strip()
            m = re.search(r"gene=([^\s]+)", header)

            if not m:
                write = False
                continue

            gene = m.group(1)

            if gene in seen:
                write = False
            else:
                seen.add(gene)
                write = True
                fout.write(line)
        else:
            if write:
                fout.write(line)
PY

    echo "${scan} gene IDs:"
    wc -l ${GENE_IDS}

    echo "${scan} all protein isoforms:"
    grep -c "^>" ${ALL_PROTEINS} || true

    echo "${scan} one isoform per gene:"
    grep -c "^>" ${ONE_ISOFORM} || true
done
EOF

