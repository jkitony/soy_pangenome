cat > plot_xpclr_manhattan.py << 'EOF'
#!/usr/bin/env python3

import argparse
import pandas as pd
import matplotlib.pyplot as plt
import re

def chr_sort_key(chrom):
    m = re.search(r"(\d+)", str(chrom))
    return int(m.group(1)) if m else 999

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--infile", required=True)
    parser.add_argument("--outfile_prefix", required=True)
    parser.add_argument("--title", required=True)
    parser.add_argument("--top_quantile", type=float, default=0.99)
    args = parser.parse_args()

    df = pd.read_csv(args.infile, sep="\t")

    required = {"chrom", "start", "stop", "xpclr"}
    missing = required - set(df.columns)
    if missing:
        raise ValueError(f"Missing columns: {missing}")

    df["chrom"] = df["chrom"].astype(str)
    df["start"] = pd.to_numeric(df["start"], errors="coerce")
    df["stop"] = pd.to_numeric(df["stop"], errors="coerce")
    df["xpclr"] = pd.to_numeric(df["xpclr"], errors="coerce")
    df = df.dropna(subset=["chrom", "start", "stop", "xpclr"])

    df["midpoint"] = (df["start"] + df["stop"]) / 2

    parts = []
    tick_pos = []
    tick_lab = []
    offset = 0

    for chrom in sorted(df["chrom"].unique(), key=chr_sort_key):
        d = df[df["chrom"] == chrom].sort_values("midpoint").copy()
        d["BPcum"] = d["midpoint"] + offset
        parts.append(d)
        tick_pos.append(d["BPcum"].median())
        tick_lab.append(chrom.replace("Chr", ""))
        offset = d["BPcum"].max()

    plot_df = pd.concat(parts, ignore_index=True)

    thr_top = plot_df["xpclr"].quantile(args.top_quantile)
    thr_95 = plot_df["xpclr"].quantile(0.95)

    top_df = df[df["xpclr"] >= thr_top].copy()
    top_df.to_csv(f"{args.outfile_prefix}.top1.full.tsv", sep="\t", index=False)

    plt.figure(figsize=(16, 5))

    for chrom in sorted(plot_df["chrom"].unique(), key=chr_sort_key):
        d = plot_df[plot_df["chrom"] == chrom]
        plt.scatter(d["BPcum"], d["xpclr"], s=7, alpha=0.75)

    plt.axhline(thr_top, linestyle="--", linewidth=1, label=f"Top 1% = {thr_top:.3f}")
    plt.axhline(thr_95, linestyle=":", linewidth=1, label=f"Top 5% = {thr_95:.3f}")

    plt.xticks(tick_pos, tick_lab, fontsize=9)
    plt.xlabel("Chromosome")
    plt.ylabel("XP-CLR score")
    plt.title(args.title)
    plt.legend(frameon=False)
    plt.tight_layout()

    plt.savefig(f"{args.outfile_prefix}.manhattan.png", dpi=300)
    plt.savefig(f"{args.outfile_prefix}.manhattan.pdf")
    plt.close()

    print(f"Top 1% threshold: {thr_top}")
    print(f"Top 5% threshold: {thr_95}")

if __name__ == "__main__":
    main()
EOF
