#!/usr/bin/env bash
set -euo pipefail

GENE_GFF="05_annotation/Wm82a5.genes.gff3"
MERGE_DIST=100000
OUTDIR="05_annotation"

mkdir -p ${OUTDIR}

echo "Using gene GFF: ${GENE_GFF}"
echo "GFF chromosome names look like:"
cut -f1 ${GENE_GFF} | grep -v "^#" | sort -u | head

for scan in domestication improvement
do
    echo
    echo "======================================"
    echo "Processing ${scan}"
    echo "======================================"

    TOP_WINDOWS="04_xpclr/plots/${scan}_XPCLR.top1.full.tsv"

    if [[ ! -s ${TOP_WINDOWS} ]]; then
        echo "ERROR: Missing ${TOP_WINDOWS}"
        exit 1
    fi

    echo "1. Convert top XP-CLR windows to BED..."

    awk 'BEGIN{OFS="\t"} NR>1 {
        print $1, $2, $3, $11
    }' ${TOP_WINDOWS} \
    > ${OUTDIR}/${scan}.top1.bed

    echo "2. Sort and merge nearby sweep windows..."

    bedtools sort -i ${OUTDIR}/${scan}.top1.bed | \
    bedtools merge -d ${MERGE_DIST} -c 4 -o max \
    > ${OUTDIR}/${scan}.top1.merged.bed

    echo "3. Convert XP-CLR chromosome names to Wm82 gnm5 GFF names..."

    awk 'BEGIN{OFS="\t"} {
        chr=$1

        # Chr01 -> glyma.Wm82.gnm5.Chr01
        if(chr ~ /^Chr[0-9]+$/){
            chr="glyma.Wm82.gnm5." chr
        }

        print chr, $2, $3, $4
    }' ${OUTDIR}/${scan}.top1.merged.bed \
    > ${OUTDIR}/${scan}.top1.merged.gnm5chr.bed

    echo "BED chromosome names after conversion:"
    cut -f1 ${OUTDIR}/${scan}.top1.merged.gnm5chr.bed | sort -u | head

    echo "4. Intersect sweep regions with Wm82a5 genes..."

    bedtools intersect \
        -a ${GENE_GFF} \
        -b ${OUTDIR}/${scan}.top1.merged.gnm5chr.bed \
        -wa -wb \
    > ${OUTDIR}/${scan}.top1.selected_genes.tsv

    echo "5. Extract Wm82a5 gene IDs..."

    awk -F'\t' '
    {
        split($9,a,";")
        for(i in a){
            if(a[i] ~ /^ID=/){
                gsub("ID=","",a[i])
                print a[i]
            }
        }
    }' ${OUTDIR}/${scan}.top1.selected_genes.tsv | \
    sort -u \
    > ${OUTDIR}/${scan}.top1.gene_ids.txt

    echo "${scan} merged sweep regions:"
    wc -l ${OUTDIR}/${scan}.top1.merged.bed

    echo "${scan} selected genes:"
    wc -l ${OUTDIR}/${scan}.top1.gene_ids.txt

done

echo
echo "6. Find shared genes between domestication and improvement..."

comm -12 \
    <(sort ${OUTDIR}/domestication.top1.gene_ids.txt) \
    <(sort ${OUTDIR}/improvement.top1.gene_ids.txt) \
> ${OUTDIR}/shared_domestication_improvement.top1.genes.txt

echo
echo "7. Write summary table..."

{
echo -e "Category\tCount"
echo -e "Domestication_top1_sweep_regions\t$(wc -l < ${OUTDIR}/domestication.top1.merged.bed)"
echo -e "Improvement_top1_sweep_regions\t$(wc -l < ${OUTDIR}/improvement.top1.merged.bed)"
echo -e "Domestication_top1_genes\t$(wc -l < ${OUTDIR}/domestication.top1.gene_ids.txt)"
echo -e "Improvement_top1_genes\t$(wc -l < ${OUTDIR}/improvement.top1.gene_ids.txt)"
echo -e "Shared_top1_genes\t$(wc -l < ${OUTDIR}/shared_domestication_improvement.top1.genes.txt)"
} > ${OUTDIR}/xpclr_top1_summary.tsv

cat ${OUTDIR}/xpclr_top1_summary.tsv

echo
echo "Done."
EOF

